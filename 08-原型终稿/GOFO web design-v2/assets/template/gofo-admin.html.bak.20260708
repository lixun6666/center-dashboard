          { key: 'ad-final', name: '站点A-D Final受投率', value: '96.8%', target: '≥96%', risk: false, uncertain: true },
          { key: 'suspect-lost', name: '疑似丢失', value: '4', target: '≤2', risk: true },
          { key: 'warehouse-kpi', name: '库内考核指标', value: '91.5%', target: '≥90%', risk: false },
        ]);
        const siteAssessDspMetrics = Vue.ref([
          { key: 'pickup-rate', name: '领件率', value: '88.4%', target: '≥90%', risk: true },
          { key: 'rate-2400', name: '2400受投率', value: '93.5%', target: '≥95%', risk: true },
          { key: 'rate-4800', name: '4800受投率', value: '95.8%', target: '≥95%', risk: false },
          { key: 'rate-7200', name: '7200完结率', value: '97.1%', target: '≥96%', risk: false, uncertain: true },
          { key: 'suspect-lost', name: '疑似丢失', value: '6', target: '≤4', risk: true },
