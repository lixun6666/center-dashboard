          { name: 'Philadelphia', value: 5980, x: 800, y: 145, level: 'low', fillColor: '#52c41a' },
          { name: 'San Antonio', value: 5120, x: 380, y: 240, level: 'low', fillColor: '#52c41a' },
          { name: 'San Diego', value: 4890, x: 160, y: 200, level: 'low', fillColor: '#52c41a' },
          { name: 'Dallas', value: 7230, x: 460, y: 200, level: 'mid', fillColor: '#fc4c02' },
          { name: 'San Jose', value: 4560, x: 90, y: 145, level: 'low', fillColor: '#52c41a' },
          { name: 'Seattle', value: 5340, x: 130, y: 70, level: 'low', fillColor: '#52c41a' },
          { name: 'Miami', value: 6780, x: 760, y: 255, level: 'mid', fillColor: '#fc4c02' },
        ]);

        const dataScreenAlerts = Vue.ref([
          { title: 'NY-01 站点完成 1,240 票早班派送', site: 'New York', time: '09:42:18', level: 'low' },
          { title: 'LAX-03 车辆 GPS 信号异常，已派工程师', site: 'Los Angeles', time: '09:41:05', level: 'mid' },
          { title: 'ORD-07 站点签收率 98.2% 达成目标', site: 'Chicago', time: '09:40:33', level: 'low' },
          { title: 'HOU-02 滞留件 23 票需客服介入', site: 'Houston', time: '09:38:12', level: 'high' },
          { title: 'PHX-01 新批次 850 票已抵达分拨', site: 'Phoenix', time: '09:37:56', level: 'low' },
          { title: 'MIA-04 暴雨预警，部分路区延迟', site: 'Miami', time: '09:35:20', level: 'mid' },
          { title: 'SEA-02 完成跨境件清关 320 票', site: 'Seattle', time: '09:33:47', level: 'low' },
          { title: 'DFW-05 司机未签入，已触发告警', site: 'Dallas', time: '09:31:09', level: 'high' },
        ]);

        const updateDataScreenTime = () => {
          const now = new Date();
          const timeStr = now.toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
          const dateStr = now.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' });
          dataScreenTime.value = timeStr;
          dataScreenDate.value = dateStr;
        };

        const initDataScreenTrendChart = (dom) => {
          if (!dom || !window.echarts) return null;
          const chart = window.echarts.init(dom, 'dark');
          chart.setOption({
            backgroundColor: 'transparent',
            grid: { top: 8, right: 12, bottom: 20, left: 40 },
            xAxis: {
              type: 'category',
              data: ['00:00', '04:00', '08:00', '12:00', '16:00', '20:00', '23:59'],
              axisLine: { lineStyle: { color: 'rgba(255,255,255,0.15)' } },
              axisLabel: { color: 'rgba(255,255,255,0.45)', fontSize: 10 },
            },
            yAxis: {
              type: 'value',
              splitLine: { lineStyle: { color: 'rgba(255,255,255,0.08)' } },
              axisLabel: { color: 'rgba(255,255,255,0.45)', fontSize: 10 },
            },
            series: [{
              data: [8200, 12300, 28400, 45600, 38900, 42100, 35600],
              type: 'line',
              smooth: true,
              symbol: 'none',
              lineStyle: { color: '#fc4c02', width: 2 },
              areaStyle: {
                color: new window.echarts.graphic.LinearGradient(0, 0, 0, 1, [
                  { offset: 0, color: 'rgba(252, 76, 2, 0.35)' },
                  { offset: 1, color: 'rgba(252, 76, 2, 0)' },
                ]),
              },
            }],
          });
          return chart;
        };

        const initDataScreenRankChart = (dom) => {
          if (!dom || !window.echarts) return null;
          const chart = window.echarts.init(dom, 'dark');
          chart.setOption({
            backgroundColor: 'transparent',
            grid: { top: 8, right: 36, bottom: 0, left: 72 },
            xAxis: { type: 'value', show: false },
            yAxis: {
              type: 'category',
              data: ['Northeast', 'Southeast', 'West', 'Southwest', 'Midwest'],
              axisLine: { show: false },
              axisTick: { show: false },
              axisLabel: { color: 'rgba(255,255,255,0.65)', fontSize: 11 },
            },
            series: [{
              type: 'bar',
              data: [32400, 28600, 25100, 19800, 16500],
              barWidth: 10,
              itemStyle: {
                borderRadius: [0, 5, 5, 0],
                color: new window.echarts.graphic.LinearGradient(0, 0, 1, 0, [
                  { offset: 0, color: '#fc4c02' },
                  { offset: 1, color: '#ff7a45' },
                ]),
              },
              label: { show: true, position: 'right', color: '#fff', fontSize: 11, formatter: '{c}' },
            }],
          });
          return chart;
        };

        const initDataScreenVehicleChart = (dom) => {
          if (!dom || !window.echarts) return null;
          const chart = window.echarts.init(dom, 'dark');
          chart.setOption({
            backgroundColor: 'transparent',
            color: ['#52c41a', '#fc4c02', '#faad14', '#ff4d4f'],
            tooltip: { trigger: 'item', formatter: '{b}: {c} ({d}%)' },
            legend: {
              orient: 'vertical',
              right: 4,
              top: 'middle',
              itemWidth: 8,
              itemHeight: 8,
              textStyle: { color: 'rgba(255,255,255,0.6)', fontSize: 10 },
            },
            series: [{
              type: 'pie',
              radius: ['42%', '66%'],
              center: ['36%', '50%'],
              avoidLabelOverlap: false,
              label: { show: false },
              itemStyle: { borderRadius: 4, borderColor: '#070b14', borderWidth: 2 },
              data: [
                { value: 1840, name: '派送中' },
                { value: 620, name: '待装车' },
                { value: 280, name: '返程中' },
                { value: 107, name: '异常停靠' },
              ],
            }],
          });
          return chart;
        };

        const initDataScreenSiteChart = (dom) => {
          if (!dom || !window.echarts) return null;
          const chart = window.echarts.init(dom, 'dark');
          chart.setOption({
            backgroundColor: 'transparent',
            grid: { top: 8, right: 12, bottom: 20, left: 36 },
            xAxis: {
              type: 'category',
              data: ['00:00', '06:00', '12:00', '18:00', '24:00'],
              axisLine: { lineStyle: { color: 'rgba(255,255,255,0.15)' } },
              axisLabel: { color: 'rgba(255,255,255,0.45)', fontSize: 10 },
            },
            yAxis: {
              type: 'value',
              splitLine: { lineStyle: { color: 'rgba(255,255,255,0.08)' } },
              axisLabel: { color: 'rgba(255,255,255,0.45)', fontSize: 10 },
            },
            series: [{
              data: [1100, 1180, 1240, 1235, 1240],
              type: 'bar',
              barWidth: 16,
              itemStyle: {
                borderRadius: [4, 4, 0, 0],
                color: new window.echarts.graphic.LinearGradient(0, 0, 0, 1, [
                  { offset: 0, color: '#1677ff' },
                  { offset: 1, color: 'rgba(22,119,255,0.2)' },
                ]),
              },
            }],
          });
          return chart;
        };

        const renderDataScreenCharts = () => {
          if (activeTab.value !== 'data-screen') return;
          Vue.nextTick(() => {
            dataScreenChartInstances.forEach((c) => c && c.dispose());
            dataScreenChartInstances = [];
            const c1 = initDataScreenTrendChart(dataScreenTrendChart.value);
            const c2 = initDataScreenRankChart(dataScreenRankChart.value);
            const c3 = initDataScreenVehicleChart(dataScreenVehicleChart.value);
            const c4 = initDataScreenSiteChart(dataScreenSiteChart.value);
            [c1, c2, c3, c4].forEach((c) => c && dataScreenChartInstances.push(c));
          });
        };

        const getFullscreenElement = () => {
          return (
            document.fullscreenElement ||
            document.webkitFullscreenElement ||
            document.mozFullScreenElement ||
            document.msFullscreenElement ||
            null
          );
        };

        const requestFullscreen = (el) => {
          const method =
            el.requestFullscreen ||
            el.webkitRequestFullscreen ||
            el.mozRequestFullScreen ||
            el.msRequestFullscreen;
          return method ? method.call(el) : Promise.reject(new Error('Fullscreen API not supported'));
        };

        const exitFullscreen = () => {
          const method =
            document.exitFullscreen ||
            document.webkitExitFullscreen ||
            document.mozCancelFullScreen ||
            document.msExitFullscreen;
          return method ? method.call(document) : Promise.reject(new Error('Fullscreen API not supported'));
        };

        const toggleDataScreenFullscreen = async () => {
          const el = dataScreenRef.value;
          if (!el) return;
          try {
            if (!getFullscreenElement()) {
              await requestFullscreen(el);
            } else {
              await exitFullscreen();
            }
          } catch (err) {
            console.error('Fullscreen toggle failed:', err);
            antd.message.warning('当前环境不支持全屏，请检查浏览器权限或iframe设置');
          }
        };

        const handleDataScreenFullscreenChange = () => {
          isDataScreenFullscreen.value = !!getFullscreenElement();
          setTimeout(() => {
            dataScreenChartInstances.forEach((c) => c && c.resize());
          }, 200);
        };

        let dataScreenTimer = null;

        Vue.watch(() => activeTab.value, (val) => {
          if (val === 'data-screen') {
            updateDataScreenTime();
            renderDataScreenCharts();
            if (!dataScreenTimer) dataScreenTimer = setInterval(updateDataScreenTime, 1000);
          } else {
            if (dataScreenTimer) {
              clearInterval(dataScreenTimer);
              dataScreenTimer = null;
            }
          }
        });

        Vue.onMounted(() => {
          document.addEventListener('fullscreenchange', handleDataScreenFullscreenChange);
          document.addEventListener('webkitfullscreenchange', handleDataScreenFullscreenChange);
          document.addEventListener('mozfullscreenchange', handleDataScreenFullscreenChange);
          document.addEventListener('MSFullscreenChange', handleDataScreenFullscreenChange);
          if (activeTab.value === 'data-screen') {
            updateDataScreenTime();
            renderDataScreenCharts();
            dataScreenTimer = setInterval(updateDataScreenTime, 1000);
          }
        });

        Vue.onUnmounted(() => {
          document.removeEventListener('fullscreenchange', handleDataScreenFullscreenChange);
          document.removeEventListener('webkitfullscreenchange', handleDataScreenFullscreenChange);
          document.removeEventListener('mozfullscreenchange', handleDataScreenFullscreenChange);
          document.removeEventListener('MSFullscreenChange', handleDataScreenFullscreenChange);
          if (dataScreenTimer) clearInterval(dataScreenTimer);
          dataScreenChartInstances.forEach((c) => c && c.dispose());
        });

        return {
          activeMenu,
          activeTab,
          showMore,
          showMoreFilter,
          expandedMenus,
          sidebarExpanded,
          searchKeyword,
          searchFocused,
          searchResults,
          openSearchResults,
          startSearchClose,
          cancelSearchClose,
          handleSearchSelect,
          language,
          timezone,
          noticeDropdownOpen,
          noticeTooltipOpen,
          langDropdownOpen,
          langTooltipOpen,
          tzDropdownOpen,
          tzTooltipOpen,
          userDropdownOpen,
          userTooltipOpen,
          startNoticeClose,
          cancelNoticeClose,
          startLangClose,
          cancelLangClose,
          startTzClose,
          cancelTzClose,
          startUserClose,
          cancelUserClose,
          noticeActiveTab,
          noticeTabs,
          noticeList,
          noticeTotalCount,
          menu,
          foundationColors,
          foundationStatusColors,
          tabs,
          tabsContainerRef,
          visibleTabs,
          hiddenTabs,
          selectMenu,
          toggleMenu,
          isMenuActive,
          closeTab,
          closeAllTabs,
          handleSidebarEnter,
          handleSidebarLeave,
          handleLanguageClick,
          handleTimezoneClick,
          handleNoticeTabClick,
          queryForm,
          queryStatusOptions,
          queryTypeOptions,
          queryDepartmentOptions,
          queryFilterExpanded,
          queryTableFullscreen,
          toggleQueryTableFullscreen,
          queryTableColumns,
          visibleQueryColumns,
          queryTableData,
          queryPagination,
          handleQueryTableSearch,
          handleQueryTableSearchAndClose,
          handleQueryTableReset,
          columnSettingOpen,
          columnSettingDraft,
          dragState,
          openColumnSetting,
          closeColumnSetting,
          applyColumnSetting,
          resetColumnSetting,
          toggleColumnVisible,
          toggleAllColumnVisible,
          setColumnFixed,
          handleColumnDragStart,
          handleColumnDragOver,
          handleColumnDragEnd,
          statusTagMap,
          showMoreFilter,
          basicForm,
          basicFormPublicOptions,
          handleBasicFormSubmit,
          handleBasicFormReset,
          advancedForm,
          selectOptions,
          sourceOptions,
          tagOptions,
          handleAdvancedFormSubmit,
          handleAdvancedFormReset,
          stepFormCurrent,
          stepForm,
          stepFormPaymentAccounts,
          stepFormReceiverAccountTypes,
          stepFormReceiverAccountTypeLabel,
          stepFormTransferTypes,
          stepFormPurposes,
          stepFormNotifyOptions,
          handleStepFormNext,
          handleStepFormPrev,
