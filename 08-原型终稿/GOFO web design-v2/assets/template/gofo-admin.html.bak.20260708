        const dataScreenMapPoints = Vue.ref([
          { name: 'New York', value: 15420, x: 820, y: 120, level: 'high', fillColor: '#ff4d4f' },
          { name: 'Los Angeles', value: 12860, x: 120, y: 160, level: 'high', fillColor: '#ff4d4f' },
          { name: 'Chicago', value: 9850, x: 580, y: 100, level: 'mid', fillColor: '#fc4c02' },
          { name: 'Houston', value: 8740, x: 430, y: 220, level: 'mid', fillColor: '#fc4c02' },
