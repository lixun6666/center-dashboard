        const siteDetailFilterForm = Vue.ref({ trackingNo: '', status: undefined, dsp: undefined });
        const siteDetailStatusOptions = Vue.ref([
          { value: 'all', label: '全部' },
          { value: 'unsigned', label: '未签入' },
          { value: 'unsent', label: '未推送' },
          { value: 'undelivered', label: '未领件' },
          { value: 'exception', label: '异常' },
        ]);
        const siteDetailDspOptions = Vue.ref([
          { value: 'PHX-ERT', label: 'PHX-ERT' },
          { value: 'PHX-DSP', label: 'PHX-DSP' },
          { value: 'LAX-ERT', label: 'LAX-ERT' },
        ]);
        const siteDetailTableData = Vue.ref([]);
        const siteDetailPagination = Vue.ref({ current: 1, pageSize: 10, total: 0 });

        const generateSiteDetailData = (count) => {
          const statuses = ['未签入', '未推送', '未领件', '派送中', '派送失败', '退回站点', '待上架'];
          const dsps = ['PHX-ERT', 'PHX-DSP', 'LAX-ERT'];
          const drivers = ['Jack Chen', 'Tom Liu', 'Mike Wang', 'David Zhang'];
          const zones = ['A01', 'A02', 'B03', 'C05'];
          const routes = ['R101', 'R102', 'R203', 'R305'];
          const orgs = ['PHX Hub', 'LAX Hub', 'ORD Hub'];
          const operators = ['System', 'Admin', 'Scanner01', 'Scanner02'];
          const nodes = ['转运中心签出', '站点签入', '任务推送', '司机领件', '派送中', '退回站点', '库内上架'];
          return Array.from({ length: count }, (_, i) => ({
            trackingNo: 'GFUS010524' + String(700000 + i).padStart(6, '0'),
            status: statuses[Math.floor(Math.random() * statuses.length)],
            dsp: dsps[Math.floor(Math.random() * dsps.length)],
            driver: drivers[Math.floor(Math.random() * drivers.length)],
            zone: zones[Math.floor(Math.random() * zones.length)],
            route: routes[Math.floor(Math.random() * routes.length)],
            lastOrg: orgs[Math.floor(Math.random() * orgs.length)],
            lastOperator: operators[Math.floor(Math.random() * operators.length)],
            lastNode: nodes[Math.floor(Math.random() * nodes.length)],
            lastTime: dayjs().subtract(Math.floor(Math.random() * 48), 'hour').format('MM/DD/YYYY HH:mm:ss'),
          }));
        };

        const openSiteMetricDetail = (cardKey, metricKey, metricName) => {
          siteDetailTitle.value = metricName || '明细';
          siteDetailModalVisible.value = true;
          siteDetailPagination.value = { current: 1, pageSize: 10, total: 56 };
          siteDetailTableData.value = generateSiteDetailData(10);
        };
        const openSiteCardDetail = (cardKey) => {
          siteDetailTitle.value = '全部明细';
          siteDetailModalVisible.value = true;
          siteDetailPagination.value = { current: 1, pageSize: 10, total: 128 };
          siteDetailTableData.value = generateSiteDetailData(10);
        };
        const handleSiteDetailSearch = () => {
          siteDetailTableData.value = generateSiteDetailData(siteDetailPagination.value.pageSize);
        };
        const handleSiteDetailReset = () => {
          siteDetailFilterForm.value = { trackingNo: '', status: undefined, dsp: undefined };
          handleSiteDetailSearch();
        };
        const handleSiteDetailExport = () => {
          antd.message.success('导出任务已创建，请至下载中心查看');
        };

        // 表单明细抽屉
        const siteFormDrawerVisible = Vue.ref(false);
        const siteFormDrawerTitle = Vue.ref('');
        const siteFormModel = Vue.ref({ trackingNo: '', status: '', duty: undefined, remark: '' });
        const openSiteFormDrawer = (title, row) => {
          siteFormDrawerTitle.value = title;
          siteFormModel.value = {
            trackingNo: row?.trackingNo || '',
            status: row?.status || '',
            duty: row?.dsp || undefined,
            remark: '',
          };
          siteFormDrawerVisible.value = true;
        };
        const submitSiteForm = () => {
          antd.message.success('提交成功');
          siteFormDrawerVisible.value = false;
        };

        const openTrackingDetail = (trackingNo) => {
          antd.message.info(`打开运单 ${trackingNo} 详情弹窗（演示）`);
        };

        const setVisualGaugeChartRef = (el, index) => {
          if (el) visualGaugeChartRefs.value[index] = el;
        };

        const generateRandomData = (len, min, max) =>
          Array.from({ length: len }, () => Math.floor(Math.random() * (max - min + 1)) + min);

        const initAreaChart = (dom, color, data) => {
          if (!dom) return null;
          const chart = echarts.init(dom);
          chart.setOption({
            grid: { left: 0, right: 0, top: 5, bottom: 5 },
            xAxis: { type: 'category', show: false, data: data.map((_, i) => i) },
            yAxis: { type: 'value', show: false },
            tooltip: { trigger: 'axis' },
            series: [{
              type: 'line',
              smooth: true,
              symbol: 'none',
              lineStyle: { width: 2, color },
              areaStyle: { color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{ offset: 0, color }, { offset: 1, color: 'rgba(255,255,255,0)' }]) },
              data,
            }],
          });
          return chart;
        };

        const initBarChart = (dom, data) => {
          if (!dom) return null;
          const chart = echarts.init(dom);
          chart.setOption({
            grid: { left: 0, right: 0, top: 5, bottom: 5 },
            xAxis: { type: 'category', show: false, data: data.map((_, i) => i) },
            yAxis: { type: 'value', show: false },
            tooltip: { trigger: 'axis' },
            series: [{
              type: 'bar',
              barWidth: '60%',
              itemStyle: { color: '#1890ff', borderRadius: [2, 2, 0, 0] },
              data,
            }],
          });
          return chart;
        };

        const initPieChart = (dom) => {
          if (!dom) return null;
          const chart = echarts.init(dom);
          chart.setOption({
            tooltip: { trigger: 'item' },
            series: [{
              type: 'pie',
              radius: ['55%', '75%'],
              center: ['50%', '50%'],
              avoidLabelOverlap: false,
              label: {
                show: true,
                position: 'center',
                formatter: '{b}\n{c}',
                fontSize: 14,
                color: 'rgba(0,0,0,0.45)',
              },
              emphasis: { label: { show: true, fontSize: 16, fontWeight: 'bold' } },
              labelLine: { show: false },
              data: dashboardPieLegend.value.map((item) => ({ value: item.percent, name: item.name, itemStyle: { color: item.color } })),
            }],
          });
          return chart;
        };

        const initStationChart = (dom, value) => {
          if (!dom) return null;
          const chart = echarts.init(dom);
          chart.setOption({
            series: [{
              type: 'pie',
              radius: ['70%', '90%'],
              center: ['50%', '50%'],
              silent: true,
              label: { show: false },
              data: [
                { value, itemStyle: { color: '#1890ff' } },
                { value: 100 - value, itemStyle: { color: '#f0f0f0' } },
              ],
            }],
          });
          return chart;
        };

        const initLineChart = (dom) => {
          if (!dom) return null;
          const chart = echarts.init(dom);
          const xData = Array.from({ length: 24 }, (_, i) => {
            const h = 8 + Math.floor(i / 2);
            const m = i % 2 === 0 ? '00' : '30';
            return `${h.toString().padStart(2, '0')}:${m}`;
          });
          chart.setOption({
            tooltip: { trigger: 'axis' },
            legend: { data: ['AAAA', 'BBBBBB'], bottom: 0 },
            grid: { left: 48, right: 24, top: 24, bottom: 72 },
            xAxis: { type: 'category', boundaryGap: false, data: xData },
            yAxis: { type: 'value' },
            dataZoom: [{ type: 'inside', start: 0, end: 100 }, { start: 0, end: 100 }],
            series: [
              { name: 'AAAA', type: 'line', smooth: false, data: generateRandomData(24, 10, 110), itemStyle: { color: '#1890ff' } },
              { name: 'BBBBBB', type: 'line', smooth: false, data: generateRandomData(24, 10, 110), itemStyle: { color: '#52c41a' } },
            ],
          });
          return chart;
        };

        const initVisualTrendChart = (dom) => {
          if (!dom) return null;
          const chart = echarts.init(dom);
          const data = visualTrendData.value;
          chart.setOption({
            tooltip: {
              trigger: 'axis',
              formatter: (params) => `${params[0].name}<br/>完成 ${params[0].value} 单`,
            },
            grid: { left: 0, right: 8, top: 16, bottom: 24 },
            xAxis: {
              type: 'category',
              data: data.map((d) => d.day),
              axisLine: { lineStyle: { color: '#f0f0f0' } },
              axisTick: { show: false },
              axisLabel: { color: 'rgba(0,0,0,0.45)', fontSize: 12 },
            },
            yAxis: {
              type: 'value',
              splitLine: { lineStyle: { color: '#f0f0f0', type: 'dashed' } },
              axisLabel: { color: 'rgba(0,0,0,0.45)', fontSize: 12 },
            },
            series: [{
              type: 'bar',
              data: data.map((d) => ({
                value: d.value,
                itemStyle: {
                  color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                    { offset: 0, color: '#ff7a45' },
                    { offset: 1, color: '#fc4c02' },
                  ]),
                },
              })),
              barWidth: '36%',
              itemStyle: { borderRadius: [6, 6, 0, 0] },
              emphasis: {
                itemStyle: {
                  color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                    { offset: 0, color: '#ff9c6e' },
                    { offset: 1, color: '#ff7a45' },
                  ]),
                },
              },
              label: {
                show: true,
                position: 'top',
                color: '#fc4c02',
                fontSize: 11,
                fontWeight: 500,
                formatter: (p) => p.value >= 1400 ? p.value : '',
              },
            }],
          });
          return chart;
        };

        const initVisualGaugeChart = (dom, value) => {
          if (!dom) return null;
          const chart = echarts.init(dom);
          chart.setOption({
            series: [{
              type: 'pie',
              radius: ['75%', '95%'],
              center: ['50%', '50%'],
              startAngle: 90,
              label: { show: false },
              data: [
                { value, itemStyle: { color: '#fc4c02' } },
                { value: 100 - value, itemStyle: { color: '#f0f0f0' } },
              ],
            }],
          });
          return chart;
        };

        const renderDashboardCharts = () => {
          const tab = activeTab.value;
          if (tab !== 'dashboard-basic' && tab !== 'dashboard-visual') return;
          Vue.nextTick(() => {
            chartInstances.forEach((c) => c && c.dispose());
            chartInstances.length = 0;
            if (tab === 'dashboard-basic') {
              const c1 = initAreaChart(statChart1.value, '#a45de9', generateRandomData(12, 10, 50));
              const c2 = initBarChart(statChart2.value, generateRandomData(12, 20, 80));
              const c3 = initAreaChart(statChart3.value, '#13c2c2', generateRandomData(12, 40, 90));
              const c4 = initAreaChart(miniChart1.value, '#1890ff', generateRandomData(10, 20, 60));
              const c5 = initAreaChart(miniChart2.value, '#1890ff', generateRandomData(10, 10, 40));
              const c6 = initPieChart(pieChart.value);
              const c7 = initLineChart(lineChart.value);
              [c1, c2, c3, c4, c5, c6, c7].forEach((c) => c && chartInstances.push(c));
              stationChartRefs.value.forEach((dom, index) => {
                const c = initStationChart(dom, dashboardStations.value[index]?.value || 0);
                c && chartInstances.push(c);
              });
            } else if (tab === 'dashboard-visual') {
              const c1 = initVisualTrendChart(visualTrendChart.value);
              c1 && chartInstances.push(c1);
              visualGaugeChartRefs.value.forEach((dom, index) => {
                const stat = visualStats.value[index];
                if (stat && stat.type === 'gauge') {
                  const value = parseFloat(stat.value);
                  const c = initVisualGaugeChart(dom, isNaN(value) ? 0 : value);
                  c && chartInstances.push(c);
                }
              });
            }
          });
        };

        Vue.watch(() => activeTab.value, (val) => {
          if (val === 'dashboard-basic' || val === 'dashboard-visual') renderDashboardCharts();
        });

        Vue.onMounted(() => {
          if (activeTab.value === 'dashboard-basic' || activeTab.value === 'dashboard-visual') renderDashboardCharts();
          window.addEventListener('resize', () => chartInstances.forEach((c) => c && c.resize()));
        });

        Vue.onUnmounted(() => {
          chartInstances.forEach((c) => c && c.dispose());
        });

        const isMenuActive = (item) => {
          if (activeMenu.value === item.key) return true;
          if (item.children) {
            return item.children.some((child) => child.key === activeMenu.value);
          }
          return false;
        };

