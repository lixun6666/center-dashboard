        ]);
        const siteAssessTableData = Vue.ref([
          { dsp: 'PHX-ERT', pickupRate: '91.2%', should: '420', remaining: '18', rate2400: '95.2%', should2400: '380', rate4800: '96.5%', should4800: '360', rate7200: '97.8%', wait: '12', suspectLost: '2', nearBroken: '0', ad48h: '95.2%', adFinal: '97.1%', onShelfRate: '93.5%', offShelfRate: '94.2%' },
          { dsp: 'PHX-DSP', pickupRate: '85.6%', should: '380', remaining: '42', rate2400: '91.8%', should2400: '340', rate4800: '93.5%', should4800: '320', rate7200: '95.2%', wait: '28', suspectLost: '6', nearBroken: '2', ad48h: '91.8%', adFinal: '94.5%', onShelfRate: '89.2%', offShelfRate: '88.6%' },
          { dsp: 'LAX-ERT', pickupRate: '93.8%', should: '310', remaining: '6', rate2400: '96.5%', should2400: '290', rate4800: '98.2%', should4800: '280', rate7200: '98.5%', wait: '8', suspectLost: '1', nearBroken: '0', ad48h: '96.5%', adFinal: '98.2%', onShelfRate: '95.8%', offShelfRate: '96.1%' },
        ]);
        const siteAssessPagination = Vue.ref({ current: 1, pageSize: 10, total: 3 });
        const openSiteAssessDetail = (key, name) => {
