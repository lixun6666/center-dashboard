          handleStepFormAgain,
          addManagementRow,
          removeManagementRow,
          editDrawerVisible,
          editForm,
          editRowIndex,
          openEditDrawer,
          closeEditDrawer,
          saveEditDrawer,
          detailModalVisible,
          detailRow,
          openDetailModal,
          closeDetailModal,
          detailTableData,
          detailPagination,
          detailFilter,
          detailFilterOptions,
          detailProductList,
          detailCurrentStep,
          routeNodes,
          detailRelatedList,
          detailRelatedPagination,
          handleDetailFilterReset,
          handleDetailFilterSearch,
          courierForm,
          courierFilterExpanded,
          courierData,
          courierPagination,
          courierDrawerVisible,
          selectedCourier,
          openCourierDetail,
