        const siteAssessActiveColumns = Vue.computed(() => {
          const map = {
            'pickup-rate': [{ field: 'pickupRate', title: '当前领件率' }, { field: 'should', title: '今日应领' }, { field: 'remaining', title: '剩余达标个数' }],
            'rate-2400': [{ field: 'rate2400', title: '2400受投率' }, { field: 'should2400', title: '今日应派' }, { field: 'remaining', title: '剩余达标个数' }],
            'rate-4800': [{ field: 'rate4800', title: '4800受投率' }, { field: 'should4800', title: '今日应派' }, { field: 'remaining', title: '剩余达标个数' }],
            'rate-7200': [{ field: 'rate7200', title: '72H完结率' }, { field: 'wait', title: '今日待处理' }, { field: 'remaining', title: '剩余达标个数' }],
            'suspect-lost': [{ field: 'suspectLost', title: '疑似丢失' }, { field: 'nearBroken', title: '即将断更' }],
            'ad-48h': [{ field: 'ad48h', title: 'A-D48H受投率' }, { field: 'should', title: '今日应派' }, { field: 'remaining', title: '剩余达标个数' }],
            'ad-final': [{ field: 'adFinal', title: 'A-D Final受投率' }, { field: 'should', title: '今日应派' }, { field: 'remaining', title: '剩余达标个数' }],
            'warehouse-kpi': [{ field: 'onShelfRate', title: '上架/重派及时率' }, { field: 'offShelfRate', title: '下架及时率' }],
          };
          return map[siteAssessActiveMetric.value] || map['pickup-rate'];
        });
        const siteAssessDspFilter = Vue.ref({ org: undefined });
        const siteAssessDspFilterOptions = Vue.ref([
          { value: 'PHX-ERT', label: 'PHX-ERT' },
          { value: 'PHX-DSP', label: 'PHX-DSP' },
