    <symbol id="icon-question-circle" viewBox="64 64 896 896"><path d="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm0 820c-205.4 0-372-166.6-372-372s166.6-372 372-372 372 166.6 372 372-166.6 372-372 372z"/><path d="M512 336c-44.2 0-80 35.8-80 80h64c0-8.8 7.2-16 16-16s16 7.2 16 16c0 13.3-10.7 24-24 24h-8v48h64v-16c35.3 0 64-28.7 64-64 0-44.2-35.8-80-80-80zM512 640h-64v64h64v-64z"/></symbol>
    <symbol id="icon-bell" viewBox="64 64 896 896"><path d="M816 768h-24V428c0-141.1-104.3-257.7-240-277.1V112c0-22.1-17.9-40-40-40s-40 17.9-40 40v38.9C336.3 170.3 232 286.9 232 428v340h-24c-17.7 0-32 14.3-32 32v32c0 17.7 14.3 32 32 32h608c17.7 0 32-14.3 32-32v-32c0-17.7-14.3-32-32-32zM512 888c-30.9 0-56-25.1-56-56h112c0 30.9-25.1 56-56 56z"/></symbol>
