  <div id="app">
    <a-config-provider :theme="{ token: { colorPrimary: '#fc4c02' } }">
      <!-- Top Header -->
      <header class="gofo-header">
      <div class="gofo-header-left">
        <div class="gofo-logo">
          <img src="./assets/GOFO-white.png" alt="GOFO" />
        </div>
        <div class="gofo-search-wrap" @mouseenter="cancelSearchClose" @mouseleave="startSearchClose">
          <a-input
            v-model:value="searchKeyword"
            class="gofo-search"
            placeholder="请输入"
            @focus="openSearchResults"
            @blur="startSearchClose"
          >
            <template #suffix>
              <gofo-icon type="search"></gofo-icon>
            </template>
          </a-input>
          <div v-if="searchFocused && searchResults.length" class="gofo-search-results">
            <div
              v-for="item in searchResults"
              :key="item.key"
              class="gofo-search-result-item"
              @mousedown.prevent="handleSearchSelect(item.key)"
            >
              {{ item.label }}
            </div>
          </div>
        </div>
      </div>
      <div class="gofo-header-right">
        <a-dropdown :arrow="false" placement="bottomCenter" trigger="click" v-model:open="noticeDropdownOpen">
          <a-tooltip title="消息通知" placement="bottom" :open="noticeTooltipOpen">
            <div class="gofo-header-badge gofo-header-notice" @mouseenter="cancelNoticeClose(); noticeTooltipOpen = true" @mouseleave="startNoticeClose(); noticeTooltipOpen = false">
              <gofo-icon type="bell" style="font-size: 18px; color: #fff;"></gofo-icon>
            </div>
          </a-tooltip>
          <template #overlay>
            <div class="notice-dropdown" @mouseenter="cancelNoticeClose" @mouseleave="startNoticeClose">
              <div class="notice-tabs">
                <div
                  v-for="tab in noticeTabs"
                  :key="tab.key"
                  class="notice-tab"
                  :class="{ active: noticeActiveTab === tab.key }"
                  @click.stop="handleNoticeTabClick(tab.key)"
                >
                  <span>{{ tab.label }}</span>
                </div>
              </div>
              <div class="notice-list">
                <div
                  v-for="item in noticeList"
                  :key="item.id"
                  class="notice-item"
                >
                  <a-tooltip :title="item.title" placement="topLeft">
                    <div class="notice-item-title">{{ item.title }}</div>
                  </a-tooltip>
                  <a-tooltip :title="item.desc" placement="topLeft">
                    <div class="notice-item-desc">{{ item.desc }}</div>
                  </a-tooltip>
                </div>
              </div>
            </div>
          </template>
        </a-dropdown>
        <a-dropdown :arrow="false" placement="bottomRight" trigger="click" v-model:open="langDropdownOpen">
          <a-tooltip title="语言" placement="bottom" :open="langTooltipOpen">
            <div class="gofo-header-select" @mouseenter="cancelLangClose(); langTooltipOpen = true" @mouseleave="startLangClose(); langTooltipOpen = false">
              <span>{{ language }}</span>
              <gofo-icon type="caret-down"></gofo-icon>
            </div>
          </a-tooltip>
          <template #overlay>
            <a-menu :selected-keys="[language]" @mouseenter="cancelLangClose" @mouseleave="startLangClose" @click="handleLanguageClick">
              <a-menu-item key="English">English</a-menu-item>
              <a-menu-item key="中文">中文</a-menu-item>
              <a-menu-item key="español">español</a-menu-item>
            </a-menu>
          </template>
        </a-dropdown>
        <a-dropdown :arrow="false" placement="bottomRight" trigger="click" v-model:open="tzDropdownOpen">
          <a-tooltip title="时区" placement="bottom" :open="tzTooltipOpen">
            <div class="gofo-header-select" @mouseenter="cancelTzClose(); tzTooltipOpen = true" @mouseleave="startTzClose(); tzTooltipOpen = false">
              <span>{{ timezone }}</span>
              <gofo-icon type="caret-down"></gofo-icon>
            </div>
          </a-tooltip>
          <template #overlay>
            <a-menu :selected-keys="[timezone]" @mouseenter="cancelTzClose" @mouseleave="startTzClose" @click="handleTimezoneClick">
              <a-menu-item key="太平洋时间">太平洋时间</a-menu-item>
              <a-menu-item key="东部时间">东部时间</a-menu-item>
              <a-menu-item key="UTC">UTC</a-menu-item>
              <a-menu-item key="北京时间">北京时间</a-menu-item>
            </a-menu>
          </template>
        </a-dropdown>
        <a-dropdown :arrow="false" placement="bottomRight" trigger="click" v-model:open="userDropdownOpen">
          <a-tooltip title="账户" placement="bottom" :open="userTooltipOpen">
            <div class="gofo-header-user" @mouseenter="cancelUserClose(); userTooltipOpen = true" @mouseleave="startUserClose(); userTooltipOpen = false">
              <div class="gofo-header-avatar">
                <gofo-icon type="user"></gofo-icon>
              </div>
              <span class="gofo-header-username">张三</span>
            </div>
          </a-tooltip>
          <template #overlay>
            <a-menu @mouseenter="cancelUserClose" @mouseleave="startUserClose">
              <a-menu-item>个人资料</a-menu-item>
              <a-menu-item>账户设置</a-menu-item>
              <a-menu-divider />
              <a-menu-item>退出登录</a-menu-item>
            </a-menu>
          </template>
        </a-dropdown>
      </div>
    </header>

    <div class="gofo-layout">
      <!-- Sidebar -->
      <aside
        class="gofo-sidebar"
        :class="{ expanded: sidebarExpanded }"
        @mouseenter="handleSidebarEnter"
        @mouseleave="handleSidebarLeave"
      >
        <nav class="gofo-menu">
          <div v-for="item in menu" :key="item.key">
            <div
              v-if="!item.children"
              class="gofo-menu-item"
              :class="{ active: isMenuActive(item) }"
              @click="selectMenu(item.key)"
            >
              <div class="item-left">
                <gofo-icon :type="item.icon"></gofo-icon>
                <span class="gofo-menu-text">{{ item.label }}</span>
              </div>
            </div>
            <div v-else>
              <div
                class="gofo-menu-item"
                :class="{ active: isMenuActive(item) }"
                @click="toggleMenu(item.key)"
              >
                <div class="item-left">
                  <gofo-icon :type="item.icon"></gofo-icon>
                  <span class="gofo-menu-text">{{ item.label }}</span>
                </div>
                <gofo-icon type="caret-down" class="gofo-menu-arrow" :class="{ open: expandedMenus.includes(item.key) }"></gofo-icon>
              </div>
              <div
                class="gofo-submenu"
                :class="{ open: expandedMenus.includes(item.key) }"
              >
                <div
                  v-for="sub in item.children"
                  :key="sub.key"
                  class="gofo-submenu-item"
                  :class="{ active: activeMenu === sub.key }"
                  @click="selectMenu(sub.key)"
                >
                  <span>{{ sub.label }}</span>
                </div>
              </div>
            </div>
          </div>
        </nav>
        <div class="gofo-sidebar-footer">
          <gofo-icon type="menu-fold"></gofo-icon>
          <span class="gofo-menu-text">收起菜单</span>
        </div>
      </aside>

      <!-- Main -->
      <main class="gofo-main">
        <!-- Tabs Bar -->
        <div class="gofo-tabs-bar">
          <div ref="tabsContainerRef" class="gofo-tabs-list">
            <div
              v-for="tab in visibleTabs"
              :key="tab.key"
              class="gofo-tab-card"
              :class="{ active: activeTab === tab.key }"
              @click="activeTab = tab.key"
            >
              <span>{{ tab.label }}</span>
              <gofo-icon v-if="tab.closable" type="close" class="gofo-tab-close" @click.stop="closeTab(tab.key)"></gofo-icon>
            </div>
          </div>
          <div class="gofo-tabs-extra">
            <a-dropdown v-if="hiddenTabs.length" placement="bottomRight" :trigger="['hover']">
              <div class="gofo-tab-more">
                <gofo-icon type="ellipsis"></gofo-icon>
              </div>
              <template #overlay>
                <a-menu>
                  <a-menu-item v-for="tab in hiddenTabs" :key="tab.key">
                    <div class="gofo-tab-menu-item" @click="activeTab = tab.key">
                      <span>{{ tab.label }}</span>
                      <gofo-icon v-if="tab.closable" type="close" class="gofo-tab-menu-close" @click.stop="closeTab(tab.key)"></gofo-icon>
                    </div>
                  </a-menu-item>
                  <a-menu-divider></a-menu-divider>
                  <a-menu-item @click="closeAllTabs">关闭全部</a-menu-item>
                </a-menu>
              </template>
            </a-dropdown>
          </div>
        </div>

        <!-- Content Area -->
        <div class="gofo-content">
          <!-- 基本框架 -->
          <template v-if="activeTab === 'foundation'">
            <div class="foundation-empty">
              <!-- 基础框架内容区已清空，仅保留固定 L 型导航框架 -->
            </div>
          </template>

          <!-- 数据看板 - 基础模版（GOFO Web 设计规范总览） -->
          <template v-if="activeTab === 'dashboard-basic'">
            <div class="dashboard-page">
              <!-- 顶部统计卡片 -->
              <div class="dashboard-stat-row">
                <div class="dashboard-stat-card">
                  <div class="dashboard-stat-header">
                    <span class="dashboard-stat-title">Total</span>
                    <a-tooltip title="指标说明"><gofo-icon type="question-circle"></gofo-icon></a-tooltip>
                  </div>
                  <div class="dashboard-stat-value">126,560</div>
                  <div class="dashboard-stat-trend">
                    <span>A Change 12% <span class="trend-up">▲</span></span>
                  </div>
                  <div class="dashboard-stat-trend">
                    <span>B Change 11% <span class="trend-down">▼</span></span>
                  </div>
                  <div class="dashboard-stat-footer">Daily 12,423</div>
                </div>
                <div class="dashboard-stat-card">
                  <div class="dashboard-stat-header">
                    <span class="dashboard-stat-title">BBB</span>
                    <a-tooltip title="指标说明"><gofo-icon type="question-circle"></gofo-icon></a-tooltip>
                  </div>
                  <div class="dashboard-stat-value">8,846</div>
                  <div ref="statChart1" class="dashboard-stat-chart"></div>
                  <div class="dashboard-stat-footer">Daily 1,234</div>
                </div>
                <div class="dashboard-stat-card">
                  <div class="dashboard-stat-header">
                    <span class="dashboard-stat-title">CCC</span>
                    <a-tooltip title="指标说明"><gofo-icon type="question-circle"></gofo-icon></a-tooltip>
                  </div>
                  <div class="dashboard-stat-value">6,560</div>
                  <div ref="statChart2" class="dashboard-stat-chart"></div>
                  <div class="dashboard-stat-footer">Conversion Rate 60%</div>
                </div>
                <div class="dashboard-stat-card">
                  <div class="dashboard-stat-header">
                    <span class="dashboard-stat-title">DDD</span>
                    <a-tooltip title="指标说明"><gofo-icon type="question-circle"></gofo-icon></a-tooltip>
                  </div>
                  <div class="dashboard-stat-value">78%</div>
                  <div ref="statChart3" class="dashboard-stat-chart"></div>
                  <div class="dashboard-stat-footer">Change 12% <span class="trend-up">▲</span></div>
                </div>
              </div>

              <!-- 中间两栏 -->
              <div class="dashboard-middle-row">
                <div class="gofo-card dashboard-card">
                  <div class="dashboard-card-head">
                    <span class="dashboard-card-title">This is title</span>
                    <a-dropdown :trigger="['click']">
                      <a-button type="text"><gofo-icon type="ellipsis"></gofo-icon></a-button>
                      <template #overlay>
                        <a-menu>
                          <a-menu-item>操作一</a-menu-item>
                          <a-menu-item>操作二</a-menu-item>
                        </a-menu>
                      </template>
                    </a-dropdown>
                  </div>
                  <div class="dashboard-mini-stat-row">
                    <div class="dashboard-mini-stat">
                      <div class="dashboard-mini-stat-label">AAAA <a-tooltip title="指标说明"><gofo-icon type="question-circle"></gofo-icon></a-tooltip></div>
                      <div class="dashboard-mini-stat-value">12,321 <span class="trend-up">17.1 ▲</span></div>
                      <div ref="miniChart1" class="dashboard-mini-chart"></div>
                    </div>
                    <div class="dashboard-mini-stat">
                      <div class="dashboard-mini-stat-label">BBBB <a-tooltip title="指标说明"><gofo-icon type="question-circle"></gofo-icon></a-tooltip></div>
                      <div class="dashboard-mini-stat-value">2.7 <span class="trend-up">26.2 ▲</span></div>
                      <div ref="miniChart2" class="dashboard-mini-chart"></div>
                    </div>
                  </div>
                  <vxe-table :data="dashboardTableData" border stripe class="dashboard-table" size="medium">
                    <vxe-column field="number" title="Number"></vxe-column>
                    <vxe-column field="name" title="Name">
                      <template #default="{ row }">
                        <a class="dashboard-link">{{ row.name }}</a>
                      </template>
                    </vxe-column>
                    <vxe-column field="address" title="Address"></vxe-column>
                    <vxe-column field="weeklyRange" title="Weekly Range" sortable>
                      <template #default="{ row }">
                        <span class="dashboard-status-dot" :class="row.status"></span>
                        <span>Status</span>
                      </template>
                    </vxe-column>
                  </vxe-table>
                  <div class="dashboard-table-footer">
                    <a-pagination v-model:current="dashboardTablePagination.current" :total="dashboardTablePagination.total" size="small" />
                  </div>
                </div>

                <div class="gofo-card dashboard-card">
                  <div class="dashboard-card-head">
                    <span class="dashboard-card-title">This is title</span>
                    <div class="dashboard-card-extra">
                      <a-radio-group v-model:value="dashboardPieType" size="small">
                        <a-radio-button value="all">All</a-radio-button>
                        <a-radio-button value="aaaa">AAAA</a-radio-button>
                        <a-radio-button value="bbbb">BBBB</a-radio-button>
                      </a-radio-group>
                      <a-dropdown :trigger="['click']">
                        <a-button type="text" style="margin-left: 8px"><gofo-icon type="ellipsis"></gofo-icon></a-button>
                        <template #overlay>
                          <a-menu>
                            <a-menu-item>操作一</a-menu-item>
                            <a-menu-item>操作二</a-menu-item>
                          </a-menu>
                        </template>
                      </a-dropdown>
                    </div>
                  </div>
                  <div class="dashboard-pie-wrap">
                    <div ref="pieChart" class="dashboard-pie-chart"></div>
                    <div class="dashboard-pie-legend">
                      <div v-for="(item, index) in dashboardPieLegend" :key="index" class="dashboard-pie-legend-item">
                        <span class="dashboard-pie-legend-dot" :style="{ background: item.color }"></span>
                        <span class="dashboard-pie-legend-name">{{ item.name }}</span>
                        <span class="dashboard-pie-legend-percent">{{ item.percent }}%</span>
                        <span class="dashboard-pie-legend-value">{{ item.value }}</span>
                      </div>
                    </div>
                  </div>
                  <div class="dashboard-pie-summary">
                    <div v-for="(item, index) in dashboardPieSummary" :key="index" class="dashboard-pie-summary-item">
                      <div class="dashboard-pie-summary-label">{{ item.label }}</div>
                      <div class="dashboard-pie-summary-value">{{ item.value }}</div>
                      <div class="dashboard-pie-summary-trend" :class="item.trend > 0 ? 'trend-up' : 'trend-down'">
                        {{ Math.abs(item.trend) }}% <span>{{ item.trend > 0 ? '▲' : '▼' }}</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- 底部图表 -->
              <div class="gofo-card dashboard-bottom-card">
                <div class="dashboard-station-row">
                  <div v-for="(item, index) in dashboardStations" :key="index" class="dashboard-station-item">
                    <div class="dashboard-station-title">{{ item.title }}</div>
                    <div class="dashboard-station-body">
                      <div class="dashboard-station-info">
                        <div class="dashboard-station-label">Order Number</div>
                        <div class="dashboard-station-value">{{ item.value }}%</div>
                      </div>
                      <div :ref="el => setStationChartRef(el, index)" class="dashboard-station-chart"></div>
                    </div>
                  </div>
                </div>
                <div ref="lineChart" class="dashboard-line-chart"></div>
              </div>

            </div>
          </template>

          <!-- 数据看板 - 强视觉模版 -->
          <template v-else-if="activeTab === 'dashboard-visual'">
            <div class="visual-dashboard-page">
              <!-- 顶部欢迎横幅 -->
              <div class="visual-hero-banner">
                <div class="visual-hero-left">
                  <div class="visual-hero-meta">
                    <span>{{ visualToday }}</span>
                    <span class="visual-hero-weather"><gofo-icon type="environment"></gofo-icon> 晴 28°C</span>
                  </div>
                  <h1 class="visual-hero-title">{{ visualGreeting }}，王队长 👋</h1>
                  <div class="visual-hero-subtitle">GOFO 与你并肩同行 ❤️</div>
                  <p class="visual-hero-desc">今日是你与 GOFO 携手同行的第 <strong>1,024</strong> 天 · 今天也辛苦了，记得提醒骑手路上注意安全</p>
                  <div class="visual-hero-actions">
                    <a-button type="primary" class="visual-hero-btn-primary">查看今日调度 →</a-button>
                    <a-button class="visual-hero-btn-secondary">发送早会通知</a-button>
                  </div>
                </div>
                <div class="visual-hero-right">
                  <div class="visual-rank-card">
                    <div class="visual-rank-header">
                      <span>本月综合排名</span>
                      <span class="visual-rank-tag">较上月 4 <span class="visual-rank-arrow">▲</span></span>
                    </div>
                    <div class="visual-rank-main">
                      <span class="visual-rank-label">第</span>
                      <span class="visual-rank-value">3</span>
                      <span class="visual-rank-label">名</span>
                      <span class="visual-rank-total">/ 128 家服务商</span>
                    </div>
                    <div class="visual-rank-level">
                      <span class="visual-rank-badge"><gofo-icon type="star"></gofo-icon> 金牌服务商</span>
                    </div>
                    <div class="visual-rank-progress">
                      <div class="visual-rank-progress-bar">
                        <div class="visual-rank-progress-fill" :style="{ width: visualRankProgress + '%' }"></div>
                      </div>
                      <div class="visual-rank-progress-info">
                        <span>还差 1,800 分，本月订单再冲一冲就到啦！</span>
                        <span>{{ visualRankProgress }}%</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- 顶部统计卡片 -->
              <div class="visual-stat-row">
                <div v-for="(item, index) in visualStats" :key="index" class="visual-stat-card">
                  <div class="visual-stat-header">
                    <span class="visual-stat-title">{{ item.title }}</span>
                    <span v-if="item.trend" class="visual-stat-trend-badge" :class="item.trend > 0 ? 'up' : 'down'">
                      {{ item.trend > 0 ? '+' : '' }}{{ item.trend }}%
                    </span>
                  </div>
                  <div class="visual-stat-body">
                    <div class="visual-stat-info">
                      <div class="visual-stat-value">{{ item.value }}</div>
                      <div v-if="item.sub" class="visual-stat-sub">{{ item.sub }}</div>
                    </div>
                    <div v-if="item.type === 'gauge'" class="visual-stat-gauge">
                      <div :ref="el => setVisualGaugeChartRef(el, index)" class="visual-stat-gauge-chart"></div>
                    </div>
                    <div v-else-if="item.type === 'progress'" class="visual-stat-progress-mini">
                      <div class="visual-stat-progress-mini-bar">
                        <div class="visual-stat-progress-mini-fill" :style="{ width: item.ratio + '%' }"></div>
                      </div>
                      <div class="visual-stat-progress-mini-dots">
                        <span v-for="n in 3" :key="n" class="visual-stat-progress-mini-dot" :class="{ active: n <= item.activeDots }"></span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- 中部内容区 -->
              <div class="visual-middle-grid">
                <!-- 左侧 -->
                <div class="visual-middle-left">
                  <!-- 7日订单趋势 -->
                  <div class="visual-card">
                    <div class="visual-card-head">
                      <div>
                        <div class="visual-card-title">近 7 日订单趋势</div>
                        <div class="visual-card-subtitle">共 8,642 单 · 环比 +12%</div>
                      </div>
                      <div class="visual-card-legend">
                        <span class="visual-legend-dot complete"></span>
                        <span>完成</span>
                      </div>
                    </div>
                    <div ref="visualTrendChart" class="visual-trend-chart"></div>
                  </div>

                  <!-- 今日司机出勤 -->
                  <div class="visual-card visual-driver-card">
                    <div class="visual-card-head">
                      <div class="visual-card-title">今日司机出勤</div>
                      <a class="visual-card-link">全部司机 →</a>
                    </div>
                    <div class="visual-driver-summary">
                      <div class="visual-driver-summary-item">
                        <span class="visual-driver-summary-dot online"></span>
                        <span>在线 42</span>
                      </div>
                      <div class="visual-driver-summary-item">
                        <span class="visual-driver-summary-dot rest"></span>
                        <span>休息 14</span>
                      </div>
                      <div class="visual-driver-summary-item">
                        <span class="visual-driver-summary-dot leave"></span>
                        <span>请假 4</span>
                      </div>
                    </div>
                    <div class="visual-driver-progress">
                      <div class="visual-driver-progress-fill" style="width: 75%"></div>
                    </div>
                    <div class="visual-driver-list">
                      <div v-for="(driver, idx) in visualDrivers" :key="idx" class="visual-driver-item">
                        <div class="visual-driver-avatar" :style="{ background: driver.avatarColor }">{{ driver.name[0] }}</div>
                        <div class="visual-driver-info">
                          <div class="visual-driver-name">{{ driver.name }}</div>
                          <div class="visual-driver-meta">今日 {{ driver.orders }} 单 · 准时 {{ driver.rate }}%</div>
                        </div>
                        <div v-if="driver.tag" class="visual-driver-tag" :class="driver.tagType">{{ driver.tag }}</div>
                        <span v-else class="visual-driver-status-dot" :class="driver.status"></span>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- 中间：服务商排行榜 -->
                <div class="visual-middle-center">
                  <div class="visual-card visual-rank-list-card">
                    <div class="visual-card-head">
                      <div>
                        <div class="visual-card-title">服务商排行榜</div>
                        <div class="visual-card-subtitle">本月 · 综合评分</div>
                      </div>
                    </div>
                    <div class="visual-rank-list">
                      <div v-for="(item, idx) in visualRankList" :key="idx" class="visual-rank-list-item" :class="{ active: item.isSelf }">
                        <div class="visual-rank-list-order" :class="{ top: idx < 3 }">{{ idx + 1 }}</div>
                        <div class="visual-rank-list-avatar" :style="{ background: item.color }">
                          <span>{{ item.name[0] }}</span>
                        </div>
                        <div class="visual-rank-list-info">
                          <div class="visual-rank-list-name">{{ item.name }}</div>
                          <div v-if="item.isSelf" class="visual-rank-list-tips">距第 2 名仅差 330 分</div>
                        </div>
                        <div class="visual-rank-list-score">{{ item.score.toLocaleString() }}</div>
                        <div v-if="item.isSelf" class="visual-rank-list-self">我的排名</div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- 右侧 -->
                <div class="visual-middle-right">
                  <!-- 成就勋章 -->
                  <div class="visual-card visual-medal-card">
                    <div class="visual-card-head">
                      <div class="visual-card-title">成就勋章</div>
                      <span class="visual-card-extra">6 / 8 已解锁</span>
                    </div>
                    <div class="visual-medal-grid">
                      <div v-for="(medal, idx) in visualMedals" :key="idx" class="visual-medal-item" :class="{ locked: medal.locked }">
                        <div class="visual-medal-icon" :style="{ background: medal.bg }">
                          <gofo-icon :type="medal.icon"></gofo-icon>
                        </div>
                        <div class="visual-medal-name">{{ medal.name }}</div>
                      </div>
                    </div>
                  </div>

                  <!-- 待办提醒 -->
                  <div class="visual-card visual-todo-card">
                    <div class="visual-card-head">
                      <div class="visual-card-title">待办提醒</div>
                      <span class="visual-card-extra">4 条待处理</span>
                    </div>
                    <div class="visual-todo-list">
                      <div v-for="(todo, idx) in visualTodos" :key="idx" class="visual-todo-item">
                        <div class="visual-todo-icon" :style="{ background: todo.bg }">
                          <gofo-icon :type="todo.icon"></gofo-icon>
                        </div>
                        <div class="visual-todo-info">
                          <div class="visual-todo-title">{{ todo.title }}</div>
                          <div class="visual-todo-desc">{{ todo.desc }}</div>
                        </div>
                      </div>
                    </div>
                    <div class="visual-todo-actions">
                      <a-button type="primary" class="visual-todo-btn-primary">去提醒</a-button>
                      <a-button class="visual-todo-btn-secondary">稍后</a-button>
                    </div>
                  </div>

                  <!-- 里程碑达成 -->
                  <div class="visual-milestone-card">
                    <div class="visual-milestone-icon">🎉</div>
                    <div class="visual-milestone-label">里程碑达成</div>
                    <div class="visual-milestone-title">本月已突破</div>
                    <div class="visual-milestone-value">3 万单</div>
                    <p class="visual-milestone-desc">团队又创新高，GOFO 为通达配送的每一位伙伴喝彩 👏</p>
                  </div>
                </div>
              </div>
            </div>
          </template>

          <!-- 数据大屏 -->
          <template v-else-if="activeTab === 'data-screen'">
            <div ref="dataScreenRef" class="data-screen-page">
              <!-- 大屏头部 -->
              <div class="data-screen-header">
                <div class="data-screen-header-left">
                  <div class="data-screen-title">全美派送实时数据大屏</div>
                  <div class="data-screen-subtitle">US Delivery Real-time Data Screen</div>
                </div>
                <div class="data-screen-header-center">
                  <div class="data-screen-time">{{ dataScreenTime }}</div>
                  <div class="data-screen-date">{{ dataScreenDate }}</div>
                </div>
                <div class="data-screen-header-right">
                  <a-button class="data-screen-fullscreen-btn" @click="toggleDataScreenFullscreen">
                    <gofo-icon :type="isDataScreenFullscreen ? 'fullscreen-exit-outlined' : 'fullscreen-outlined'"></gofo-icon>
                    <span style="margin-left: 6px">{{ isDataScreenFullscreen ? '退出全屏' : '全屏' }}</span>
                  </a-button>
                </div>
              </div>

              <!-- KPI 指标行 -->
              <div class="data-screen-kpi-row">
                <div v-for="kpi in dataScreenKpiList" :key="kpi.label" class="data-screen-kpi">
                  <div class="data-screen-kpi-icon" :style="{ background: kpi.color + '20', color: kpi.color }">
                    <gofo-icon :type="kpi.icon"></gofo-icon>
                  </div>
                  <div class="data-screen-kpi-main">
                    <div class="data-screen-kpi-label">{{ kpi.label }}</div>
                    <div class="data-screen-kpi-value" :style="{ color: kpi.color }">{{ kpi.value }}</div>
                    <div class="data-screen-kpi-trend" :class="kpi.trendType">
                      <gofo-icon :type="kpi.trendIcon"></gofo-icon>
                      <span>{{ kpi.trend }}</span>
                    </div>
                  </div>
                </div>
              </div>

              <!-- 中间主区域 -->
              <div class="data-screen-body">
                <!-- 实时地图 -->
                <div class="data-screen-map-card">
                  <div class="data-screen-map-header">
                    <div class="data-screen-card-title">实时派送网络</div>
                    <div class="data-screen-map-legend">
                      <span class="data-screen-legend-item"><i class="data-screen-legend-dot hub"></i>枢纽</span>
                      <span class="data-screen-legend-item"><i class="data-screen-legend-dot high"></i>高密度</span>
                      <span class="data-screen-legend-item"><i class="data-screen-legend-dot mid"></i>中密度</span>
                      <span class="data-screen-legend-item"><i class="data-screen-legend-dot low"></i>低密度</span>
                    </div>
                  </div>
                  <div class="data-screen-map-wrap">
                    <div class="data-screen-grid"></div>
                    <svg class="data-screen-fake-map" viewBox="0 0 1000 320" preserveAspectRatio="xMidYMid meet">
                      <defs>
                        <linearGradient id="ds-line-grad" x1="0%" y1="0%" x2="100%" y2="0%">
                          <stop offset="0%" stop-color="rgba(252,76,2,0)" />
                          <stop offset="50%" stop-color="rgba(252,76,2,0.6)" />
                          <stop offset="100%" stop-color="rgba(252,76,2,0)" />
                        </linearGradient>
                        <filter id="ds-glow">
                          <feGaussianBlur stdDeviation="2.5" result="coloredBlur"/>
                          <feMerge>
                            <feMergeNode in="coloredBlur"/>
                            <feMergeNode in="SourceGraphic"/>
                          </feMerge>
                        </filter>
                      </defs>

                      <!-- 背景美国轮廓（抽象） -->
                      <path class="data-screen-us-shape" d="M120,90 L220,80 L260,70 L340,65 L420,60 L500,58 L580,60 L660,68 L740,78 L820,92 L880,110 L900,140 L890,180 L860,220 L800,250 L720,270 L620,280 L500,282 L380,280 L280,270 L200,250 L140,220 L110,180 L100,140 Z" />

                      <!-- 枢纽 -->
                      <g class="data-screen-hub" :style="{ transform: `translate(${dataScreenHub.x}px, ${dataScreenHub.y}px)` }">
                        <circle r="18" fill="rgba(252,76,2,0.2)" />
                        <circle r="10" fill="#fc4c02" filter="url(#ds-glow)" />
                        <text y="-28" text-anchor="middle" fill="#fff" font-size="12" font-weight="600">中央分拨中心</text>
                      </g>

                      <!-- 连接线和跳动箭头 -->
                      <g v-for="(flow, idx) in dataScreenFlows" :key="idx">
                        <path
                          :id="'ds-flow-' + idx"
                          class="data-screen-flow-line"
                          :d="`M${dataScreenHub.x},${dataScreenHub.y} Q${flow.cx},${flow.cy} ${flow.tx},${flow.ty}`"
                        />
                        <circle r="4" :fill="flow.color" filter="url(#ds-glow)">
                          <animateMotion :dur="flow.dur + 's'" repeatCount="indefinite" :path="`M${dataScreenHub.x},${dataScreenHub.y} Q${flow.cx},${flow.cy} ${flow.tx},${flow.ty}`" />
                        </circle>
                        <polygon
                          class="data-screen-flow-arrow"
                          points="0,-4 8,0 0,4"
                          :fill="flow.color"
                        >
                          <animateMotion :dur="flow.dur + 's'" repeatCount="indefinite" :path="`M${dataScreenHub.x},${dataScreenHub.y} Q${flow.cx},${flow.cy} ${flow.tx},${flow.ty}`" rotate="auto" />
                        </polygon>
                      </g>

                      <!-- 城市点 -->
                      <g v-for="point in dataScreenMapPoints" :key="point.name" class="data-screen-map-point" :class="point.level">
                        <circle :cx="point.x" :cy="point.y" r="12" :fill="point.fillColor" opacity="0.2">
                          <animate attributeName="r" values="12;18;12" dur="2s" repeatCount="indefinite" />
                          <animate attributeName="opacity" values="0.2;0;0.2" dur="2s" repeatCount="indefinite" />
                        </circle>
                        <circle :cx="point.x" :cy="point.y" r="5" :fill="point.fillColor" filter="url(#ds-glow)" />
                        <text :x="point.x" :y="point.y - 14" text-anchor="middle" fill="rgba(255,255,255,0.85)" font-size="10">{{ point.name }}</text>
                        <text :x="point.x" :y="point.y + 22" text-anchor="middle" :fill="point.fillColor" font-size="9" font-weight="600">{{ point.value }}</text>
                      </g>
                    </svg>
                  </div>
                </div>

                <!-- 右侧两列 -->
                <div class="data-screen-side-col">
                  <div class="data-screen-chart-card">
                    <div class="data-screen-card-title">区域派送 TOP5</div>
                    <div ref="dataScreenRankChart" class="data-screen-chart"></div>
                  </div>
                  <div class="data-screen-chart-card">
                    <div class="data-screen-card-title">车辆状态分布</div>
                    <div ref="dataScreenVehicleChart" class="data-screen-chart"></div>
                  </div>
                </div>
              </div>

              <!-- 底部行 -->
              <div class="data-screen-bottom">
                <div class="data-screen-chart-card">
                  <div class="data-screen-card-title">24h 派送趋势</div>
                  <div ref="dataScreenTrendChart" class="data-screen-chart"></div>
                </div>
                <div class="data-screen-alert-card">
                  <div class="data-screen-card-title">实时告警</div>
                  <div class="data-screen-alert-list">
                    <div v-for="(alert, idx) in dataScreenAlerts" :key="idx" class="data-screen-alert-item" :class="alert.level">
                      <div class="data-screen-alert-level"></div>
                      <div class="data-screen-alert-content">
                        <div class="data-screen-alert-title">{{ alert.title }}</div>
                        <div class="data-screen-alert-meta">{{ alert.site }} · {{ alert.time }}</div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="data-screen-chart-card">
                  <div class="data-screen-card-title">站点在线状态</div>
                  <div ref="dataScreenSiteChart" class="data-screen-chart"></div>
                </div>
              </div>
            </div>
          </template>

          <!-- 站点实时看板 -->
          <!-- 站点实时看板 -->
          <!-- 站点实时看板 -->
          <template v-else-if="activeTab === 'site-realtime-dashboard'">
            <div class="site-dashboard-page">
              <!-- 筛选区 -->
              <div class="site-filter-card">
                <a-form layout="vertical" :model="siteFilterForm" class="site-filter-form">
                  <div class="site-filter-grid">
                    <a-form-item label="大区" class="site-filter-item">
                      <a-select v-model:value="siteFilterForm.region" placeholder="请选择大区" :options="siteRegionOptions" @change="handleSiteRegionChange" />
                    </a-form-item>
                    <a-form-item label="站点" class="site-filter-item">
                      <a-select v-model:value="siteFilterForm.site" placeholder="请选择站点" :options="siteSiteOptions" />
                    </a-form-item>
                    <a-form-item label=" " class="site-filter-item site-filter-actions">
                      <a-button type="primary" @click="handleSiteFilterSearch">查询</a-button>
                    </a-form-item>
                  </div>
                </a-form>
              </div>

              <!-- 四个 Tab -->
              <div class="site-tabs-card">
                <a-tabs v-model:activeKey="siteActiveTab" type="card">
                  <!-- 概览 -->
                  <a-tab-pane key="overview" tab="概览">
                    <div class="site-dashboard-page" style="padding-bottom: 0;">
                      <!-- 顶部欢迎与站点排名得分 -->
                      <div class="site-hero-banner">
                        <div class="site-hero-left">
                          <div class="site-hero-meta">
                            <span class="site-hero-greeting">Hi，王站长</span>
                            <span class="site-hero-dot">·</span>
                            <span>PHX-01 站点</span>
                            <span class="site-hero-dot">·</span>
                            <span>美西时间</span>
                            <span class="site-hero-dot">·</span>
                            <span>数据更新 09:42</span>
                          </div>
                          <h1 class="site-hero-title">今日作业重点：未签入 <strong>128</strong> 票 · 未领件 <strong>215</strong> 票</h1>
                          <p class="site-hero-desc">早高峰已过，重点关注滞留件与 DSP 领件进度，有任何异常记得及时同步客服与问题件系统。辛苦了！</p>
                          <div class="site-hero-actions">
                            <a-button type="primary" class="site-hero-btn-primary" @click="openSiteCardDetail('todo')">查看异常明细</a-button>
                            <a-button class="site-hero-btn-secondary" @click="handleSiteFilterSearch">刷新数据</a-button>
                          </div>
                        </div>
                        <div class="site-hero-right">
                          <div class="site-score-card">
                            <div class="site-score-label">昨日综合得分</div>
                            <div class="site-score-value">92.5</div>
                            <div class="site-score-trend">优于均值 2.3 分</div>
                          </div>
                          <div class="site-rank-card">
                            <div class="site-rank-label">大区排名</div>
                            <div class="site-rank-value">3</div>
                            <div class="site-rank-total">/ 28 个站点</div>
                          </div>
                        </div>
                      </div>

                      <!-- 正向环节 -->
                      <div class="site-section">
                        <div class="site-section-header">
                          <div class="site-section-title">正向环节</div>
                          <div class="site-section-subtitle">签入 → 任务 → 领件 → 派送</div>
                        </div>
                        <div class="site-link-grid site-forward-grid">
                          <div v-for="(card, idx) in siteForwardCards" :key="card.key" class="site-link-card">
                            <div class="site-link-card-head">
                              <div class="site-link-order" :class="'order-' + (idx + 1)">{{ idx + 1 }}</div>
                              <div>
                                <div class="site-link-title">{{ card.name }}</div>
                                <div class="site-link-duty">责任方：{{ card.duty }}</div>
                              </div>
                            </div>
                            <div class="site-link-main" @click="openSiteMetricDetail(card.key, card.mainMetric.key, card.mainMetric.name)">
                              <div class="site-link-metric-name">
                                {{ card.mainMetric.name }}
                                <a-tooltip :title="card.mainMetric.tip" placement="top">
                                  <gofo-icon type="question-circle-outlined" class="site-link-tip-icon"></gofo-icon>
                                </a-tooltip>
                              </div>
                              <div class="site-link-metric-value" :class="{ risk: card.mainMetric.risk }">{{ card.mainMetric.value }}</div>
                            </div>
                            <div class="site-link-subs">
                              <div v-for="sub in card.subMetrics" :key="sub.key" class="site-link-sub" @click="openSiteMetricDetail(card.key, sub.key, sub.name)">
                                <span class="site-link-sub-label">{{ sub.name }}</span>
                                <span class="site-link-sub-value" :class="{ risk: sub.risk }">{{ sub.value }}</span>
                              </div>
                            </div>
                            <div class="site-link-footer">
                              <span class="site-link-detail" @click="openSiteCardDetail(card.key)">查看明细 →</span>
                            </div>
                          </div>
                        </div>
                      </div>

                      <!-- 逆向环节 -->
                      <div class="site-section">
                        <div class="site-section-header">
                          <div class="site-section-title">逆向环节</div>
                          <div class="site-section-subtitle">待退回站点 → 库内异常 / 问题件 → 待退回上一级</div>
                        </div>
                        <div class="site-link-grid site-reverse-grid">
                          <div v-for="(card, idx) in siteReverseCards" :key="card.key" class="site-link-card" :class="{ wide: card.wide }">
                            <div class="site-link-card-head">
                              <div class="site-link-order" :class="'order-' + (idx + 1)">{{ idx + 1 }}</div>
                              <div>
                                <div class="site-link-title">{{ card.name }}</div>
                                <div class="site-link-duty">责任方：{{ card.duty }}</div>
                              </div>
                            </div>
                            <div v-if="!card.groups" class="site-link-main" @click="openSiteMetricDetail(card.key, card.mainMetric.key, card.mainMetric.name)">
                              <div class="site-link-metric-name">
                                {{ card.mainMetric.name }}
                                <a-tooltip :title="card.mainMetric.tip" placement="top">
                                  <gofo-icon type="question-circle-outlined" class="site-link-tip-icon"></gofo-icon>
                                </a-tooltip>
                              </div>
                              <div class="site-link-metric-value" :class="{ risk: card.mainMetric.risk }">{{ card.mainMetric.value }}</div>
                            </div>
                            <div v-if="!card.groups" class="site-link-subs">
                              <div v-for="sub in card.subMetrics" :key="sub.key" class="site-link-sub" @click="openSiteMetricDetail(card.key, sub.key, sub.name)">
                                <span class="site-link-sub-label">{{ sub.name }}</span>
                                <span class="site-link-sub-value" :class="{ risk: sub.risk }">{{ sub.value }}</span>
                              </div>
                            </div>
                            <div v-else class="site-link-groups">
                              <div v-for="group in card.groups" :key="group.title" class="site-link-group">
                                <div class="site-link-group-title">{{ group.title }}</div>
                                <div class="site-link-group-items">
                                  <div v-for="item in group.items" :key="item.key" class="site-link-sub" @click="openSiteMetricDetail(card.key, item.key, item.name)">
                                    <span class="site-link-sub-label">{{ item.name }}</span>
                                    <span class="site-link-sub-value" :class="{ risk: item.risk }">{{ item.value }}</span>
                                  </div>
                                </div>
                              </div>
                            </div>
                            <div class="site-link-footer">
                              <span class="site-link-detail" @click="openSiteCardDetail(card.key)">查看明细 →</span>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </a-tab-pane>

                  <!-- 库内监控 -->
                  <a-tab-pane key="warehouse" tab="库内监控">
                    <div class="site-dashboard-page" style="padding-bottom: 0;">
                      <!-- 第一行：卸车区域 / DSP交取区域 / 司机签到数据 -->
                      <div class="site-module-row three">
                        <!-- 卸车区域 -->
                        <div class="site-module-card">
                          <div class="site-module-card-head">
                            <div class="site-module-card-title">卸车区域</div>
                          </div>
                          <div class="site-module-metrics" style="grid-template-columns: 1fr 1fr;">
                            <div v-for="m in siteUnloadMetrics" :key="m.key" class="site-module-metric" @click="openSiteMetricDetail('unload', m.key, m.name)">
                              <div class="site-module-metric-main">
                                <div class="site-module-metric-name">
                                  {{ m.name }}
                                  <a-tooltip :title="m.tip" placement="top"><gofo-icon type="question-circle-outlined" class="site-link-tip-icon"></gofo-icon></a-tooltip>
                                </div>
                                <div class="site-module-metric-value" :class="{ risk: m.risk }">{{ m.value }}</div>
                              </div>
                            </div>
                          </div>
                          <div class="site-link-footer">
                            <span class="site-link-detail" @click="openSiteCardDetail('unload')">车辆明细 →</span>
                          </div>
                        </div>
                        <!-- DSP 交取区域 -->
                        <div class="site-module-card">
                          <div class="site-module-card-head">
                            <div class="site-module-card-title">DSP 交取区域</div>
                          </div>
                          <div class="site-module-metrics">
                            <div v-for="m in siteDspHandoverMetrics" :key="m.key" class="site-module-metric" @click="openSiteMetricDetail('dsp-handover', m.key, m.name)">
                              <div class="site-module-metric-main">
                                <div class="site-module-metric-name">
                                  {{ m.name }}
                                  <a-tooltip :title="m.tip" placement="top"><gofo-icon type="question-circle-outlined" class="site-link-tip-icon"></gofo-icon></a-tooltip>
                                </div>
                                <div class="site-module-metric-value" :class="{ risk: m.risk }">{{ m.value }}</div>
                              </div>
                            </div>
                          </div>
                          <div class="site-link-footer">
                            <span class="site-link-detail" @click="openSiteCardDetail('dsp-handover')">交取明细 →</span>
                          </div>
                        </div>
                        <!-- 司机签到数据 -->
                        <div class="site-module-card">
                          <div class="site-module-card-head">
                            <div class="site-module-card-title">司机签到数据</div>
                          </div>
                          <div class="site-module-metrics">
                            <div v-for="m in siteDriverSignMetrics" :key="m.key" class="site-module-metric" @click="openSiteMetricDetail('driver-sign', m.key, m.name)">
                              <div class="site-module-metric-main">
                                <div class="site-module-metric-name">{{ m.name }}</div>
                                <div class="site-module-metric-value" :class="{ risk: m.risk }">{{ m.value }}</div>
                              </div>
                            </div>
                          </div>
                          <div class="site-link-footer">
                            <span class="site-link-detail" @click="openSiteCardDetail('driver-sign')">签到明细 →</span>
                          </div>
                        </div>
                      </div>

                      <!-- 第二行：库内异常区域 / 库内问题件 -->
                      <div class="site-module-row two">
                        <div class="site-module-card">
                          <div class="site-module-card-head">
                            <div class="site-module-card-title">库内异常区域</div>
                          </div>
                          <div class="site-link-groups">
                            <div class="site-link-group">
                              <div class="site-link-group-title">库内异常处理状态</div>
                              <div class="site-link-group-items">
                                <div v-for="m in siteWarehouseExceptionMetrics" :key="m.key" class="site-link-sub" @click="openSiteMetricDetail('warehouse-exception', m.key, m.name)">
                                  <span class="site-link-sub-label">{{ m.name }}</span>
                                  <span class="site-link-sub-value" :class="{ risk: m.risk }">{{ m.value }}</span>
                                </div>
                              </div>
                            </div>
                          </div>
                          <div class="site-link-footer">
                            <span class="site-link-detail" @click="openSiteCardDetail('warehouse-exception')">异常明细 →</span>
                          </div>
                        </div>
                        <div class="site-module-card">
                          <div class="site-module-card-head">
                            <div class="site-module-card-title">库内问题件</div>
                          </div>
                          <div class="site-link-group-items">
                            <div v-for="m in siteWarehouseIssueMetrics" :key="m.key" class="site-link-sub" @click="openSiteMetricDetail('warehouse-issue', m.key, m.name)">
                              <span class="site-link-sub-label">{{ m.name }}</span>
                              <span class="site-link-sub-value" :class="{ risk: m.risk }">{{ m.value }}</span>
                            </div>
                          </div>
                          <div class="site-link-footer">
                            <span class="site-link-detail" @click="openSiteCardDetail('warehouse-issue')">问题件明细 →</span>
                          </div>
                        </div>
                      </div>

                      <!-- 底部：各 DSP 明细 -->
                      <div class="site-module-card">
                        <div class="site-module-card-head">
                          <div class="site-module-card-title">各 DSP 明细</div>
                          <a-tabs v-model:activeKey="siteDspTaskTab" type="card" size="small" style="margin: 0;">
                            <a-tab-pane key="today" tab="今日任务"></a-tab-pane>
                            <a-tab-pane key="tomorrow" tab="次日任务"></a-tab-pane>
                          </a-tabs>
                        </div>
                        <div class="site-workbench">
                          <!-- 左侧 DSP 列表 -->
                          <div class="site-workbench-left">
                            <div class="site-workbench-filter">
                              <a-select v-model:value="siteDspFilter.dsp" placeholder="DSP 名称" :options="siteDspFilterOptions" mode="multiple" style="min-width: 160px;" />
                              <a-select v-model:value="siteDspFilter.sort" placeholder="排序方式" :options="siteDspSortOptions" style="min-width: 120px;" />
                              <a-button type="primary" size="small" @click="handleSiteDspFilter">查询</a-button>
                            </div>
                            <div class="site-workbench-list">
                              <div v-for="dsp in siteDspList" :key="dsp.id" class="site-workbench-card" :class="{ active: siteSelectedDsp === dsp.id }" @click="selectSiteDsp(dsp.id)">
                                <div class="site-workbench-card-head">
                                  <span class="site-workbench-card-name">{{ dsp.name }}</span>
                                  <a-tag v-if="dsp.risk" color="error">异常</a-tag>
                                </div>
                                <div class="site-workbench-card-metrics">
                                  <div v-for="metric in dsp.metrics" :key="metric.label" class="site-workbench-card-metric">
                                    <span class="site-workbench-card-metric-label">{{ metric.label }}</span>
                                    <span class="site-workbench-card-metric-value" :class="{ risk: metric.risk }">{{ metric.value }}</span>
                                  </div>
                                </div>
                                <div class="site-workbench-progress">
                                  <div class="site-workbench-progress-bar"><div class="site-workbench-progress-fill" :style="{ width: dsp.progress + '%' }"></div></div>
                                </div>
                              </div>
                            </div>
                          </div>
                          <!-- 右侧司机明细 -->
                          <div class="site-workbench-right">
                            <div class="site-workbench-title">{{ siteSelectedDspName }} - 司机明细</div>
                            <div class="site-workbench-filter">
                              <a-input-search v-model:value="siteDriverSearch" placeholder="快递员姓名" style="width: 180px;" @search="handleSiteDriverSearch" />
                              <a-select v-model:value="siteDriverExceptionFilter" placeholder="异常状态" :options="[{value:'all',label:'全部'},{value:'unsigned',label:'未签到'},{value:'pudo',label:'PUDO'},{value:'exception',label:'异常'}]" style="width: 120px;" />
                            </div>
                            <div v-if="siteDriverList.length" class="site-workbench-list">
                              <div v-for="driver in siteDriverList" :key="driver.id" class="site-workbench-card" @click="openSiteMetricDetail('driver-pickup', driver.id, driver.name)">
                                <div class="site-workbench-card-head">
                                  <span class="site-workbench-card-name">{{ driver.name }}</span>
                                  <span class="site-route-card-tags">
                                    <span v-for="tag in driver.tags" :key="tag" class="site-route-tag">{{ tag }}</span>
                                  </span>
                                </div>
                                <div class="site-workbench-card-metrics">
                                  <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">应领件</span><span class="site-workbench-card-metric-value">{{ driver.should }}</span></div>
                                  <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">已领件</span><span class="site-workbench-card-metric-value">{{ driver.done }}</span></div>
                                  <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">未领件</span><span class="site-workbench-card-metric-value" :class="{ risk: driver.undone > 0 }">{{ driver.undone }}</span></div>
                                  <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">领件率</span><span class="site-workbench-card-metric-value">{{ driver.rate }}%</span></div>
                                </div>
                                <div class="site-workbench-progress">
                                  <div class="site-workbench-progress-bar"><div class="site-workbench-progress-fill" :style="{ width: driver.rate + '%' }"></div></div>
                                </div>
                              </div>
                            </div>
                            <div v-else class="site-workbench-empty">暂无司机数据</div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </a-tab-pane>

                  <!-- 派送监控 -->
                  <a-tab-pane key="delivery" tab="派送监控">
                    <div class="site-dashboard-page" style="padding-bottom: 0;">
                      <!-- 顶部三模块 -->
                      <div class="site-delivery-top">
                        <!-- 派件数据 -->
                        <div class="site-module-card">
                          <div class="site-module-card-head">
                            <div class="site-module-card-title">派件数据</div>
                            <a-radio-group v-model:value="siteDeliveryBatch" size="small" @change="handleSiteDeliveryBatchChange">
                              <a-radio-button value="today">今日应派</a-radio-button>
                              <a-radio-button value="tomorrow">次日应派</a-radio-button>
                            </a-radio-group>
                          </div>
                          <div class="site-delivery-metric-row">
                            <div v-for="m in siteDeliveryDataMetrics" :key="m.key" class="site-delivery-metric" @click="openSiteMetricDetail('delivery-data', m.key, m.name)">
                              <div class="site-delivery-metric-value" :class="{ risk: m.risk }">{{ m.value }}</div>
                              <div class="site-delivery-metric-name">{{ m.name }}</div>
                            </div>
                          </div>
                        </div>
                        <!-- 派送异常 -->
                        <div class="site-module-card">
                          <div class="site-module-card-head">
                            <div class="site-module-card-title">派送异常</div>
                            <a-radio-group v-model:value="siteDeliveryExceptionView" size="small" @change="handleSiteDeliveryExceptionViewChange">
                              <a-radio-button value="dsp">按 DSP</a-radio-button>
                              <a-radio-button value="type">按异常类型</a-radio-button>
                            </a-radio-group>
                          </div>
                          <div v-if="siteDeliveryExceptionView === 'dsp'" class="site-workbench-list">
                            <div v-for="dsp in siteDeliveryExceptionDspList" :key="dsp.id" class="site-workbench-card" @click="openSiteMetricDetail('delivery-exception-dsp', dsp.id, dsp.name)">
                              <div class="site-workbench-card-head"><span class="site-workbench-card-name">{{ dsp.name }}</span><span class="site-workbench-card-metric-value" :class="{ risk: dsp.count > 10 }">{{ dsp.count }}</span></div>
                              <div class="site-workbench-card-metrics">
                                <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">排名</span><span class="site-workbench-card-metric-value">{{ dsp.rank }}</span></div>
                                <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">异常件数</span><span class="site-workbench-card-metric-value" :class="{ risk: dsp.count > 10 }">{{ dsp.count }}</span></div>
                              </div>
                            </div>
                          </div>
                          <div v-else class="site-delivery-metric-row">
                            <div v-for="m in siteDeliveryExceptionTypes" :key="m.key" class="site-delivery-metric" @click="openSiteMetricDetail('delivery-exception-type', m.key, m.name)">
                              <div class="site-delivery-metric-value" :class="{ risk: m.risk }">{{ m.value }}</div>
                              <div class="site-delivery-metric-name">{{ m.name }}</div>
                            </div>
                          </div>
                        </div>
                        <!-- DSP 问题件及工单 -->
                        <div class="site-module-card">
                          <div class="site-module-card-head">
                            <div class="site-module-card-title">DSP 问题件及工单</div>
                          </div>
                          <div class="site-delivery-metric-row">
                            <div v-for="m in siteDeliveryIssueMetrics" :key="m.key" class="site-delivery-metric" @click="openSiteMetricDetail('delivery-issue', m.key, m.name)">
                              <div class="site-delivery-metric-value" :class="{ risk: m.risk }">{{ m.value }}</div>
                              <div class="site-delivery-metric-name">{{ m.name }}</div>
                            </div>
                          </div>
                        </div>
                      </div>

                      <!-- 下方明细区：各路区明细 -->
                      <div class="site-module-card">
                        <div class="site-module-card-head">
                          <div class="site-module-card-title">各路区明细</div>
                        </div>
                        <div class="site-workbench">
                          <!-- 左侧路区/DSP 列表 -->
                          <div class="site-workbench-left">
                            <div class="site-workbench-filter">
                              <a-select v-model:value="siteRouteFilter.routes" placeholder="路区筛选" :options="siteRouteOptions" mode="multiple" style="min-width: 140px;" />
                              <a-select v-model:value="siteRouteFilter.mode" placeholder="派送模式" :options="[{value:'normal',label:'普通'},{value:'agent',label:'货代'},{value:'pudo',label:'PUDO'}]" mode="multiple" style="min-width: 120px;" />
                              <a-checkbox v-model:checked="siteRouteFilter.groupByDsp">展示 DSP 分组</a-checkbox>
                            </div>
                            <div class="site-workbench-filter">
                              <a-select v-model:value="siteRouteFilter.sort" placeholder="排序指标" :options="siteRouteSortOptions" style="min-width: 140px;" />
                              <a-select v-model:value="siteRouteFilter.order" placeholder="排序方向" :options="[{value:'asc',label:'升序'},{value:'desc',label:'降序'}]" style="min-width: 100px;" />
                              <a-button type="primary" size="small" @click="handleSiteRouteFilter">查询</a-button>
                            </div>
                            <div class="site-workbench-list">
                              <template v-if="siteRouteFilter.groupByDsp">
                                <div v-for="dsp in siteRouteDspGroups" :key="dsp.id" class="site-workbench-card" :class="{ active: siteSelectedRouteGroup === dsp.id }" @click="selectSiteRouteDsp(dsp.id)">
                                  <div class="site-workbench-card-head"><span class="site-workbench-card-name">{{ dsp.name }}</span></div>
                                  <div class="site-workbench-card-metrics">
                                    <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">当期应派</span><span class="site-workbench-card-metric-value">{{ dsp.current }}</span></div>
                                    <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">历史未派</span><span class="site-workbench-card-metric-value">{{ dsp.history }}</span></div>
                                    <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">妥投率</span><span class="site-workbench-card-metric-value">{{ dsp.deliveryRate }}%</span></div>
                                    <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">日清率</span><span class="site-workbench-card-metric-value">{{ dsp.clearRate }}%</span></div>
                                  </div>
                                </div>
                              </template>
                              <template v-else>
                                <div v-for="route in siteRouteList" :key="route.id" class="site-workbench-card" :class="{ active: siteSelectedRoute === route.id }" @click="selectSiteRoute(route.id)">
                                  <div class="site-workbench-card-head">
                                    <span class="site-workbench-card-name" style="color:#1677ff;cursor:pointer;" @click.stop="openSiteRouteDrawer(route)">{{ route.name }}</span>
                                    <span class="site-route-card-tags">
                                      <span class="site-route-tag">{{ route.difficulty }}</span>
                                      <span v-if="route.isNew" class="site-route-tag">{{ route.isNew }}</span>
                                    </span>
                                  </div>
                                  <div class="site-workbench-card-metrics">
                                    <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">PPH</span><span class="site-workbench-card-metric-value" :class="{ risk: route.pphRisk }">{{ route.pph }}</span></div>
                                    <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">妥投率</span><span class="site-workbench-card-metric-value">{{ route.deliveryRate }}%</span></div>
                                    <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">日清率</span><span class="site-workbench-card-metric-value">{{ route.clearRate }}%</span></div>
                                    <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">模式</span><span class="site-workbench-card-metric-value">{{ route.mode }}</span></div>
                                  </div>
                                </div>
                              </template>
                            </div>
                          </div>
                          <!-- 右侧司机详情 -->
                          <div class="site-workbench-right">
                            <div class="site-workbench-title">{{ siteSelectedRouteName || siteSelectedRouteGroupName }} - 司机详情</div>
                            <div class="site-workbench-filter">
                              <a-input-search v-model:value="siteRouteDriverSearch" placeholder="快递员" style="width: 160px;" @search="handleSiteRouteDriverSearch" />
                              <a-select v-model:value="siteRouteDriverException" placeholder="异常状态" :options="[{value:'all',label:'全部'},{value:'undelivered',label:'未派送'},{value:'pod',label:'POD不合规'},{value:'position',label:'妥投位置异常'},{value:'unsigned',label:'未签到'}]" style="width: 140px;" />
                              <a-button type="link" size="small" @click="openSiteDeliveryAnalysis">派送分析</a-button>
                            </div>
                            <div v-if="siteRouteDriverList.length" class="site-workbench-list">
                              <div v-for="driver in siteRouteDriverList" :key="driver.id" class="site-workbench-card" @click="openSiteMetricDetail('route-driver', driver.id, driver.name)">
                                <div class="site-workbench-card-head"><span class="site-workbench-card-name">{{ driver.name }}</span><span class="site-workbench-card-metric-value">{{ driver.deliveryRate }}%</span></div>
                                <div class="site-workbench-card-metrics">
                                  <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">应派</span><span class="site-workbench-card-metric-value">{{ driver.should }}</span></div>
                                  <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">已妥投</span><span class="site-workbench-card-metric-value">{{ driver.delivered }}</span></div>
                                  <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">派送中</span><span class="site-workbench-card-metric-value">{{ driver.delivering }}</span></div>
                                  <div class="site-workbench-card-metric"><span class="site-workbench-card-metric-label">异常</span><span class="site-workbench-card-metric-value" :class="{ risk: driver.exception > 0 }">{{ driver.exception }}</span></div>
                                </div>
                                <div class="site-workbench-progress">
                                  <div class="site-workbench-progress-bar"><div class="site-workbench-progress-fill" :style="{ width: driver.deliveryRate + '%' }"></div></div>
                                </div>
                              </div>
                            </div>
                            <div v-else class="site-workbench-empty">暂无司机数据</div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </a-tab-pane>

                  <!-- 考核监控 -->
                  <a-tab-pane key="assessment" tab="考核监控">
                    <div class="site-dashboard-page" style="padding-bottom: 0;">
                      <div class="site-assess-row">
                        <!-- 库内表现 -->
                        <div class="site-assess-card">
                          <div class="site-assess-card-head">
                            <div class="site-assess-card-title">库内表现</div>
                          </div>
                          <div class="site-assess-metrics">
                            <div v-for="m in siteAssessWarehouseMetrics" :key="m.key" class="site-assess-metric" @click="openSiteAssessDetail(m.key, m.name)">
                              <div class="site-assess-metric-name">
                                {{ m.name }}
                                <a-tooltip v-if="m.uncertain" title="口径待确认" placement="top"><gofo-icon type="warning-outlined" style="color:#faad14"></gofo-icon></a-tooltip>
                              </div>
                              <div class="site-assess-metric-value" :class="{ risk: m.risk }">{{ m.value }}</div>
                              <div class="site-assess-metric-target">目标：{{ m.target }}</div>
                            </div>
                          </div>
                        </div>
                        <!-- DSP 表现 -->
                        <div class="site-assess-card">
                          <div class="site-assess-card-head">
                            <div class="site-assess-card-title">DSP 表现</div>
                          </div>
                          <div class="site-assess-metrics">
                            <div v-for="m in siteAssessDspMetrics" :key="m.key" class="site-assess-metric" @click="openSiteAssessDetail(m.key, m.name)">
                              <div class="site-assess-metric-name">
                                {{ m.name }}
                                <a-tooltip v-if="m.uncertain" title="口径待确认" placement="top"><gofo-icon type="warning-outlined" style="color:#faad14"></gofo-icon></a-tooltip>
                              </div>
                              <div class="site-assess-metric-value" :class="{ risk: m.risk }">{{ m.value }}</div>
                              <div class="site-assess-metric-target">目标：{{ m.target }}</div>
                            </div>
                          </div>
                        </div>
                      </div>

                      <!-- 各 DSP 指标明细 -->
                      <div class="site-assess-table-card">
                        <div class="site-module-card-head" style="padding: 0 0 16px;">
                          <div class="site-module-card-title">{{ siteAssessActiveMetricName }} - 各 DSP 明细</div>
                          <div class="site-workbench-filter">
                            <a-select v-model:value="siteAssessDspFilter.org" placeholder="组织" :options="siteAssessDspFilterOptions" style="width: 160px;" />
                            <a-button @click="handleSiteAssessReset">重置</a-button>
                            <a-button type="primary" @click="handleSiteAssessSearch">查询</a-button>
                            <a-button @click="handleSiteAssessExport">导出</a-button>
                          </div>
                        </div>
                        <vxe-table :data="siteAssessTableData" :column-config="{ resizable: true }" :scroll-y="{ enabled: false }" class="site-detail-table" style="width: 100%;" :max-height="360">
                          <vxe-column field="dsp" title="组织" min-width="120" fixed="left"></vxe-column>
                          <vxe-column v-for="col in siteAssessActiveColumns" :key="col.field" :field="col.field" :title="col.title" min-width="140">
                            <template #default="{ row }">
                              <a-button v-if="col.field === 'remaining'" type="link" size="small" @click="openSiteMetricDetail('assess-remaining', row.dsp, '待补救包裹')">{{ row[col.field] }}</a-button>
                              <span v-else>{{ row[col.field] }}</span>
                            </template>
                          </vxe-column>
                        </vxe-table>
                        <div class="site-detail-pagination">
                          <a-pagination v-model:current="siteAssessPagination.current" v-model:pageSize="siteAssessPagination.pageSize" :total="siteAssessPagination.total" show-size-changer />
                        </div>
                      </div>
                    </div>
                  </a-tab-pane>
                </a-tabs>
              </div>
            </div>

            <!-- 表格明细弹窗 -->
            <a-modal
              v-model:open="siteDetailModalVisible"
              :title="siteDetailTitle"
              width="1100px"
              :footer="null"
              destroy-on-close
            >
              <div class="site-detail-modal-body">
                <div class="site-detail-filter">
                  <a-form layout="vertical" :model="siteDetailFilterForm" class="site-detail-filter-grid">
                    <a-form-item label="运单号">
                      <a-input v-model:value="siteDetailFilterForm.trackingNo" placeholder="最多输入 1000 单" />
                    </a-form-item>
                    <a-form-item label="运单状态">
                      <a-select v-model:value="siteDetailFilterForm.status" placeholder="请选择" :options="siteDetailStatusOptions" />
                    </a-form-item>
                    <a-form-item label="DSP 名称">
                      <a-select v-model:value="siteDetailFilterForm.dsp" placeholder="请选择" :options="siteDetailDspOptions" />
                    </a-form-item>
                    <a-form-item label=" " class="site-detail-filter-actions">
                      <a-button @click="handleSiteDetailReset">重置</a-button>
                      <a-button type="primary" style="margin-left: 8px;" @click="handleSiteDetailSearch">查询</a-button>
                      <a-button style="margin-left: 8px;" @click="handleSiteDetailExport">导出</a-button>
                    </a-form-item>
                  </a-form>
                </div>
                <vxe-table :data="siteDetailTableData" :column-config="{ resizable: true }" :scroll-y="{ enabled: false }" class="site-detail-table" style="width: 100%;" :max-height="420">
                  <vxe-column type="seq" title="序号" width="60" fixed="left"></vxe-column>
                  <vxe-column field="trackingNo" title="运单号" min-width="160" fixed="left">
                    <template #default="{ row }">
                      <a type="link" style="color: #1677ff; cursor: pointer;" @click="openTrackingDetail(row.trackingNo)">{{ row.trackingNo }}</a>
                    </template>
                  </vxe-column>
                  <vxe-column field="status" title="运单状态" min-width="120"></vxe-column>
                  <vxe-column field="dsp" title="DSP名称" min-width="120"></vxe-column>
                  <vxe-column field="driver" title="司机" min-width="120"></vxe-column>
                  <vxe-column field="zone" title="快递员区域" min-width="120"></vxe-column>
                  <vxe-column field="route" title="快递员路线" min-width="120"></vxe-column>
                  <vxe-column field="lastOrg" title="最新操作组织" min-width="140"></vxe-column>
                  <vxe-column field="lastOperator" title="最新操作人" min-width="120"></vxe-column>
                  <vxe-column field="lastNode" title="最新扫描节点" min-width="140"></vxe-column>
                  <vxe-column field="lastTime" title="最新操作时间" min-width="160"></vxe-column>
                </vxe-table>
                <div class="site-detail-pagination">
                  <a-pagination v-model:current="siteDetailPagination.current" v-model:pageSize="siteDetailPagination.pageSize" :total="siteDetailPagination.total" show-size-changer />
                </div>
              </div>
            </a-modal>

            <!-- 表单明细抽屉 -->
            <a-drawer
              v-model:open="siteFormDrawerVisible"
              :title="siteFormDrawerTitle"
              width="640"
              destroy-on-close
            >
              <div class="site-drawer-form">
                <a-form layout="vertical" :model="siteFormModel">
                  <a-form-item label="运单号">
                    <a-input v-model:value="siteFormModel.trackingNo" disabled />
                  </a-form-item>
                  <a-form-item label="当前状态">
                    <a-input v-model:value="siteFormModel.status" disabled />
                  </a-form-item>
                  <a-form-item label="责任方">
                    <a-select v-model:value="siteFormModel.duty" placeholder="请选择" :options="siteDetailDspOptions" />
                  </a-form-item>
                  <a-form-item label="处理说明">
                    <a-textarea v-model:value="siteFormModel.remark" :rows="4" placeholder="请输入处理说明" />
                  </a-form-item>
                  <a-form-item>
                    <a-button type="primary" @click="submitSiteForm">提交</a-button>
                    <a-button style="margin-left: 8px" @click="siteFormDrawerVisible = false">取消</a-button>
                  </a-form-item>
                </a-form>
              </div>
            </a-drawer>

            <!-- 路区详情抽屉 -->
            <a-drawer
              v-model:open="siteRouteDrawerVisible"
              :title="siteRouteDrawerTitle"
              width="720"
              destroy-on-close
            >
              <div class="site-drawer-form">
                <a-descriptions v-if="siteRouteDrawerData" :column="2" bordered size="small">
                  <a-descriptions-item label="路区名称">{{ siteRouteDrawerData.name }}</a-descriptions-item>
                  <a-descriptions-item label="分拣码">{{ siteRouteDrawerData.sortCode }}</a-descriptions-item>
                  <a-descriptions-item label="中心码">{{ siteRouteDrawerData.centerCode }}</a-descriptions-item>
                  <a-descriptions-item label="大区">{{ siteRouteDrawerData.region }}</a-descriptions-item>
                  <a-descriptions-item label="站点">{{ siteRouteDrawerData.site }}</a-descriptions-item>
                  <a-descriptions-item label="车队">{{ siteRouteDrawerData.fleet }}</a-descriptions-item>
                  <a-descriptions-item label="业务模式">{{ siteRouteDrawerData.mode }}</a-descriptions-item>
                  <a-descriptions-item label="状态">{{ siteRouteDrawerData.status }}</a-descriptions-item>
                  <a-descriptions-item label="邮编">{{ siteRouteDrawerData.zip }}</a-descriptions-item>
                  <a-descriptions-item label="路区难易度">{{ siteRouteDrawerData.difficulty }}</a-descriptions-item>
                </a-descriptions>
              </div>
            </a-drawer>
          </template>

          <template v-if="activeTab === 'query-table'">
            <div class="gofo-card query-filter-card">
              <a-form v-show="!queryFilterExpanded" layout="vertical" :model="queryForm" class="query-filter-form">
                <div class="query-filter-grid">
                  <a-form-item label="类型" class="query-filter-item">
                    <a-select v-model:value="queryForm.type" placeholder="请选择" :options="queryTypeOptions" />
                  </a-form-item>
                  <a-form-item label="规则名称" class="query-filter-item">
                    <a-input v-model:value="queryForm.name" placeholder="请输入" allow-clear />
                  </a-form-item>
                  <a-form-item label="状态" class="query-filter-item">
                    <a-select v-model:value="queryForm.status" placeholder="请选择" :options="queryStatusOptions" />
                  </a-form-item>
                  <a-form-item label="更新日期" class="query-filter-item">
                    <a-range-picker v-model:value="queryForm.dateRange" :placeholder="['开始日期', '结束日期']" />
                  </a-form-item>
                </div>
                <div class="query-filter-actions-bar">
                  <a-button @click="handleQueryTableReset">重置</a-button>
                  <a-button type="primary" style="margin-left: 8px" @click="handleQueryTableSearch">查询</a-button>
                  <a-button type="link" class="query-filter-expand-btn" style="margin-left: 8px" @click="queryFilterExpanded = true">
                    展开
                    <gofo-icon type="down-outlined"></gofo-icon>
                  </a-button>
                </div>
              </a-form>
              <div v-show="queryFilterExpanded" class="query-filter-overlay">
                <a-form layout="vertical" :model="queryForm" class="query-filter-overlay-form">
                  <div class="query-filter-overlay-grid">
                    <a-form-item label="类型" class="query-filter-item">
                      <a-select v-model:value="queryForm.type" placeholder="请选择" :options="queryTypeOptions" />
                    </a-form-item>
                    <a-form-item label="规则名称" class="query-filter-item">
                      <a-input v-model:value="queryForm.name" placeholder="请输入" allow-clear />
                    </a-form-item>
                    <a-form-item label="状态" class="query-filter-item">
                      <a-select v-model:value="queryForm.status" placeholder="请选择" :options="queryStatusOptions" />
                    </a-form-item>
                    <a-form-item label="更新日期" class="query-filter-item">
                      <a-range-picker v-model:value="queryForm.dateRange" :placeholder="['开始日期', '结束日期']" />
                    </a-form-item>
                    <a-form-item label="负责人" class="query-filter-item">
                      <a-input v-model:value="queryForm.owner" placeholder="请输入" allow-clear />
                    </a-form-item>
                    <a-form-item label="部门" class="query-filter-item">
                      <a-select v-model:value="queryForm.department" placeholder="请选择" :options="queryDepartmentOptions" />
                    </a-form-item>
                    <a-form-item label="最低金额" class="query-filter-item">
                      <a-input-number v-model:value="queryForm.minAmount" placeholder="请输入" style="width: 100%" />
                    </a-form-item>
                    <a-form-item label="最高金额" class="query-filter-item">
                      <a-input-number v-model:value="queryForm.maxAmount" placeholder="请输入" style="width: 100%" />
                    </a-form-item>
                  </div>
                </a-form>
                <div class="query-filter-overlay-footer">
                  <a-button @click="handleQueryTableReset">重置</a-button>
                  <a-button type="primary" style="margin-left: 8px" @click="handleQueryTableSearchAndClose">查询</a-button>
                  <a-button type="link" class="query-filter-expand-btn" style="margin-left: 8px" @click="queryFilterExpanded = false">
                    收起
                    <gofo-icon type="up-outlined"></gofo-icon>
                  </a-button>
                </div>
              </div>
            </div>
            <div class="gofo-card query-table-card" :class="{ 'is-fullscreen': queryTableFullscreen }">
              <div class="query-table-toolbar">
                <div class="query-table-toolbar-left">
                  <a-button>导出</a-button>
                  <a-button style="margin-left: 8px">导入</a-button>
                  <a-button type="primary" style="margin-left: 8px">新建</a-button>
                </div>
                <div class="query-table-toolbar-right">
                  <a-tooltip title="删除">
                    <a-button class="query-table-tool-btn">
                      <gofo-icon type="delete-outlined"></gofo-icon>
                    </a-button>
                  </a-tooltip>
                  <a-tooltip title="刷新">
                    <a-button class="query-table-tool-btn">
                      <gofo-icon type="reload-outlined"></gofo-icon>
                    </a-button>
                  </a-tooltip>
                  <a-popover
                    v-model:open="columnSettingOpen"
                    placement="bottomRight"
                    trigger="click"
                    overlay-class-name="query-column-setting-popover"
                  >
                    <a-tooltip title="设置">
                      <a-button class="query-table-tool-btn" @click="openColumnSetting">
                        <gofo-icon type="setting-outlined"></gofo-icon>
                      </a-button>
                    </a-tooltip>
                    <template #content>
                      <div class="query-column-setting-panel">
                        <div class="query-column-setting-header">
                          <a-checkbox
                            :checked="columnSettingDraft.every((c) => c.visible)"
                            :indeterminate="columnSettingDraft.some((c) => c.visible) && columnSettingDraft.some((c) => !c.visible)"
                            @change="toggleAllColumnVisible($event.target.checked)"
                          >
                            全部
                          </a-checkbox>
                        </div>
                        <div class="query-column-setting-body">
                          <div
                            v-for="(col, index) in columnSettingDraft"
                            :key="col.field"
                            class="query-column-setting-item"
                            :class="{ dragging: dragState.draggingIndex === index, over: dragState.overIndex === index }"
                            draggable="true"
                            @dragstart="handleColumnDragStart(index, $event)"
                            @dragover="handleColumnDragOver(index, $event)"
                            @dragend="handleColumnDragEnd"
                          >
                            <gofo-icon type="drag-outlined" class="query-column-setting-drag"></gofo-icon>
                            <a-checkbox :checked="col.visible" @change="toggleColumnVisible(index)">{{ col.title }}</a-checkbox>
                            <div class="query-column-setting-actions">
                              <a-tooltip title="冻结到左侧">
                                <gofo-icon
                                  type="vertical-right-outlined"
                                  class="query-column-setting-pin"
                                  :class="{ active: col.fixed === 'left' }"
                                  @click="setColumnFixed(index, 'left')"
                                ></gofo-icon>
                              </a-tooltip>
                              <a-tooltip title="冻结到右侧">
                                <gofo-icon
                                  type="vertical-left-outlined"
                                  class="query-column-setting-pin"
                                  :class="{ active: col.fixed === 'right' }"
                                  @click="setColumnFixed(index, 'right')"
                                ></gofo-icon>
                              </a-tooltip>
                            </div>
                          </div>
                        </div>
                        <div class="query-column-setting-footer">
                          <a-button type="link" @click="resetColumnSetting">恢复默认</a-button>
                          <div class="query-column-setting-footer-right">
                            <a-button @click="closeColumnSetting">取消</a-button>
                            <a-button type="primary" style="margin-left: 8px" @click="applyColumnSetting">确认</a-button>
                          </div>
                        </div>
                      </div>
                    </template>
                  </a-popover>
                  <a-tooltip :title="queryTableFullscreen ? '退出全屏' : '全屏'">
                    <a-button class="query-table-tool-btn" @click="toggleQueryTableFullscreen">
                      <gofo-icon :type="queryTableFullscreen ? 'fullscreen-exit-outlined' : 'fullscreen-outlined'"></gofo-icon>
                    </a-button>
                  </a-tooltip>
                </div>
              </div>
              <vxe-table
                :data="queryTableData"
                border
                stripe
                width="100%"
                auto-resize
                :column-config="{ resizable: true, drag: true }"
                :row-config="{ isHover: true, drag: true }"
                :custom-config="{ mode: 'popup' }"
                :scroll-x="{ enabled: true }"
              >
                <vxe-column type="checkbox" width="50" align="center"></vxe-column>
                <vxe-column type="seq" title="序号" width="60" align="center"></vxe-column>
                <vxe-column
                  v-for="col in visibleQueryColumns"
                  :key="col.field"
                  :field="col.field"
                  :title="col.title"
                  :min-width="col.minWidth"
                  :align="col.align || 'left'"
                  :fixed="col.fixed || undefined"
                >
                  <template v-if="col.field === 'status'" #default="{ row }">
                    <span class="query-status-cell">
                      <span class="query-status-dot" :style="{ backgroundColor: statusTagMap[row.status]?.dotColor }"></span>
                      <span class="query-status-text">{{ statusTagMap[row.status]?.text }}</span>
                    </span>
                  </template>
                </vxe-column>
                <vxe-column title="操作" width="140" align="center">
                  <template #default="{ rowIndex }">
                    <a-tooltip title="编辑">
                      <a-button type="link" size="small" class="advanced-form-action-btn">
                        <gofo-icon type="edit-outlined" class="advanced-form-action-icon"></gofo-icon>
                      </a-button>
                    </a-tooltip>
                    <a-tooltip title="详情">
                      <a-button type="link" size="small" class="advanced-form-action-btn" @click="openDetailModal(queryTableData, rowIndex)">
                        <gofo-icon type="eye-outlined" class="advanced-form-action-icon"></gofo-icon>
                      </a-button>
                    </a-tooltip>
                    <a-tooltip title="删除">
                      <a-button type="link" size="small" class="advanced-form-action-btn">
                        <gofo-icon type="delete-outlined" class="advanced-form-action-icon"></gofo-icon>
                      </a-button>
                    </a-tooltip>
                  </template>
                </vxe-column>
              </vxe-table>
              <div class="query-table-pagination">
                <a-pagination
                  v-model:current="queryPagination.current"
                  v-model:pageSize="queryPagination.pageSize"
                  :total="queryPagination.total"
                  show-size-changer
                  show-quick-jumper
                  :show-total="(total) => `共 ${total} 条`"
                />
              </div>
            </div>
          </template>

          <!-- 卡片列表 / 快递员信息 -->
          <template v-if="activeTab === 'card-list'">
            <div class="gofo-card query-filter-card">
              <a-form v-show="!courierFilterExpanded" layout="vertical" :model="courierForm" class="query-filter-form">
                <div class="query-filter-grid">
                  <a-form-item label="姓名" class="query-filter-item">
                    <a-input v-model:value="courierForm.name" placeholder="请输入" allow-clear />
                  </a-form-item>
                  <a-form-item label="手机号" class="query-filter-item">
                    <a-input v-model:value="courierForm.phone" placeholder="请输入" allow-clear />
                  </a-form-item>
                  <a-form-item label="所属省份" class="query-filter-item">
                    <a-select v-model:value="courierForm.province" placeholder="请选择" :options="courierProvinceOptions" />
                  </a-form-item>
                  <a-form-item label="所属城市" class="query-filter-item">
                    <a-select v-model:value="courierForm.city" placeholder="请选择" :options="courierCityOptions" />
                  </a-form-item>
                </div>
                <div class="query-filter-actions-bar">
                  <a-button @click="handleCourierReset">重置</a-button>
                  <a-button type="primary" style="margin-left: 8px" @click="handleCourierSearch">查询</a-button>
                  <a-button type="link" class="query-filter-expand-btn" style="margin-left: 8px" @click="courierFilterExpanded = true">
                    展开
                    <gofo-icon type="down-outlined"></gofo-icon>
                  </a-button>
                </div>
              </a-form>
              <div v-show="courierFilterExpanded" class="query-filter-overlay">
                <a-form layout="vertical" :model="courierForm" class="query-filter-overlay-form">
                  <div class="query-filter-overlay-grid">
                    <a-form-item label="姓名" class="query-filter-item">
                      <a-input v-model:value="courierForm.name" placeholder="请输入" allow-clear />
                    </a-form-item>
                    <a-form-item label="手机号" class="query-filter-item">
                      <a-input v-model:value="courierForm.phone" placeholder="请输入" allow-clear />
                    </a-form-item>
                    <a-form-item label="所属省份" class="query-filter-item">
                      <a-select v-model:value="courierForm.province" placeholder="请选择" :options="courierProvinceOptions" />
                    </a-form-item>
                    <a-form-item label="所属城市" class="query-filter-item">
                      <a-select v-model:value="courierForm.city" placeholder="请选择" :options="courierCityOptions" />
                    </a-form-item>
                    <a-form-item label="所属站点" class="query-filter-item">
                      <a-select v-model:value="courierForm.site" placeholder="请选择" :options="courierSiteOptions" />
                    </a-form-item>
                    <a-form-item label="工号" class="query-filter-item">
                      <a-input v-model:value="courierForm.employeeNo" placeholder="请输入" allow-clear />
                    </a-form-item>
                    <a-form-item label="入职日期" class="query-filter-item">
                      <a-range-picker v-model:value="courierForm.entryDateRange" :placeholder="['开始日期', '结束日期']" />
                    </a-form-item>
                    <a-form-item label="在职状态" class="query-filter-item">
                      <a-select v-model:value="courierForm.status" placeholder="请选择" :options="courierStatusOptions" />
                    </a-form-item>
                  </div>
                </a-form>
                <div class="query-filter-overlay-footer">
                  <a-button @click="handleCourierReset">重置</a-button>
                  <a-button type="primary" style="margin-left: 8px" @click="handleCourierSearchAndClose">查询</a-button>
                  <a-button type="link" class="query-filter-expand-btn" style="margin-left: 8px" @click="courierFilterExpanded = false">
                    收起
                    <gofo-icon type="up-outlined"></gofo-icon>
                  </a-button>
                </div>
              </div>
            </div>
            <div class="gofo-card card-list-card">
              <div class="card-list-grid">
                <div class="card-list-item" v-for="item in courierData" :key="item.id" @click="openCourierDetail(item)">
                  <div
                    class="card-list-status-badge"
                    :class="'status-' + (item.deliveryStatus === '派送中' ? 'progress' : item.deliveryStatus === '结束派送' ? 'completed' : 'pending')"
                  >{{ item.deliveryStatus }}</div>
                  <div class="card-list-avatar-wrap">
                    <img class="card-list-avatar" :src="item.avatar" :alt="item.name" />
                  </div>
                  <div class="card-list-content">
                    <div class="card-list-title">{{ item.name }}</div>
                    <div class="card-list-info">
                      <div class="card-list-info-row"><span class="card-list-label">工号：</span>{{ item.employeeNo }}</div>
                      <div class="card-list-info-row"><span class="card-list-label">省市区：</span>{{ item.province }} {{ item.city }} {{ item.district }}</div>
                      <div class="card-list-info-row"><span class="card-list-label">站点：</span>{{ item.site }}</div>
                      <div class="card-list-progress">
                        <div class="card-list-progress-label">今日派送量</div>
                        <div class="card-list-progress-bar">
                          <div
                            class="card-list-progress-fill"
                            :class="{ completed: item.deliveryStatus === '结束派送' }"
                            :style="{ width: Math.min((item.deliveryCurrent / item.deliveryTotal) * 100, 100) + '%' }"
                          ></div>
                        </div>
                        <div class="card-list-progress-text">{{ item.deliveryCurrent }}/{{ item.deliveryTotal }}</div>
                      </div>
                    </div>
                  </div>
                  <div class="card-list-actions" @click.stop>
                    <a-tooltip title="详情">
                      <a-button type="link" class="card-list-action-btn" @click="openCourierDetail(item)">
                        <gofo-icon type="eye-outlined"></gofo-icon>
                      </a-button>
                    </a-tooltip>
                    <a-tooltip title="编辑">
                      <a-button type="link" class="card-list-action-btn">
                        <gofo-icon type="edit-outlined"></gofo-icon>
                      </a-button>
                    </a-tooltip>
                    <a-tooltip title="删除">
                      <a-button type="link" class="card-list-action-btn">
                        <gofo-icon type="delete-outlined"></gofo-icon>
                      </a-button>
                    </a-tooltip>
                    <a-tooltip title="更多">
                      <a-button type="link" class="card-list-action-btn">
                        <gofo-icon type="more-outlined"></gofo-icon>
                      </a-button>
                    </a-tooltip>
                  </div>
                </div>
              </div>
              <div class="query-table-pagination">
                <a-pagination
                  v-model:current="courierPagination.current"
                  v-model:pageSize="courierPagination.pageSize"
                  :total="courierPagination.total"
                  show-size-changer
                  show-quick-jumper
                  :show-total="(total) => `共 ${total} 条`"
                />
              </div>
            </div>
            <a-drawer
              v-model:open="courierDrawerVisible"
              title="快递员详情"
              width="520"
              placement="right"
              class="courier-detail-drawer"
            >
              <div class="courier-detail">
                <div class="courier-detail-header">
                  <img class="courier-detail-avatar" :src="selectedCourier?.avatar" :alt="selectedCourier?.name" />
                  <div class="courier-detail-name">{{ selectedCourier?.name }}</div>
                  <a-tag :color="selectedCourier?.status === '在职' ? 'success' : selectedCourier?.status === '离职' ? 'default' : 'warning'">{{ selectedCourier?.status }}</a-tag>
                </div>
                <a-descriptions :column="1" bordered>
                  <a-descriptions-item label="工号">{{ selectedCourier?.employeeNo }}</a-descriptions-item>
                  <a-descriptions-item label="手机号">{{ selectedCourier?.phone }}</a-descriptions-item>
                  <a-descriptions-item label="身份证号">{{ selectedCourier?.idCard }}</a-descriptions-item>
                  <a-descriptions-item label="性别">{{ selectedCourier?.gender }}</a-descriptions-item>
                  <a-descriptions-item label="入职日期">{{ selectedCourier?.entryDate }}</a-descriptions-item>
                  <a-descriptions-item label="所属省份">{{ selectedCourier?.province }}</a-descriptions-item>
                  <a-descriptions-item label="所属城市">{{ selectedCourier?.city }}</a-descriptions-item>
                  <a-descriptions-item label="所属站点">{{ selectedCourier?.site }}</a-descriptions-item>
                  <a-descriptions-item label="详细地址">{{ selectedCourier?.address }}</a-descriptions-item>
                </a-descriptions>
              </div>
            </a-drawer>
          </template>

          <!-- 基础表单 -->
          <template v-if="activeTab === 'basic-form'">
            <div class="gofo-card basic-form-card">
              <a-form :model="basicForm" :label-col="{ span: 5 }" :wrapper-col="{ span: 16 }">
                <a-form-item label="标题" name="title" :rules="[{ required: true, message: '请输入标题' }]">
                  <a-input v-model:value="basicForm.title" placeholder="请输入标题" class="basic-form-control" />
                </a-form-item>
                <a-form-item label="起止日期" name="dateRange">
                  <a-range-picker v-model:value="basicForm.dateRange" class="basic-form-control" />
                </a-form-item>
                <a-form-item label="目标描述" name="goal">
                  <a-textarea v-model:value="basicForm.goal" :rows="4" placeholder="请输入目标描述" class="basic-form-textarea" />
                </a-form-item>
                <a-form-item label="衡量标准" name="metrics">
                  <a-textarea v-model:value="basicForm.metrics" :rows="4" placeholder="请输入衡量标准" class="basic-form-textarea" />
                </a-form-item>
                <a-form-item label="客户" name="client">
                  <a-input v-model:value="basicForm.client" placeholder="请描述你服务的客户" class="basic-form-control" />
                </a-form-item>
                <a-form-item label="邀评人" name="inviter">
                  <a-input v-model:value="basicForm.inviter" placeholder="请直接 @姓名/工号，最多可邀请 5 人" class="basic-form-control" />
                </a-form-item>
                <a-form-item label="权重" name="weight">
                  <a-input-number v-model:value="basicForm.weight" :min="0" :max="100" placeholder="请输入" style="width: 160px" />
                  <span class="basic-form-hint">%</span>
                </a-form-item>
                <a-form-item label="目标公开" name="isPublic">
                  <a-radio-group v-model:value="basicForm.isPublic">
                    <a-radio :value="1">公开</a-radio>
                    <a-radio :value="2">部分公开</a-radio>
                    <a-radio :value="3">不公开</a-radio>
                  </a-radio-group>
                  <div class="basic-form-extra" v-if="basicForm.isPublic === 2">
                    <span>公开给</span>
                    <a-select v-model:value="basicForm.publicTo" mode="multiple" placeholder="请选择" :options="basicFormPublicOptions" style="width: 280px; margin-left: 8px" />
                  </div>
                </a-form-item>
                <a-form-item :wrapper-col="{ offset: 5, span: 16 }">
                  <a-button @click="handleBasicFormReset">重置</a-button>
                  <a-button type="primary" style="margin-left: 8px" @click="handleBasicFormSubmit">提交</a-button>
                </a-form-item>
              </a-form>
            </div>
          </template>

          <!-- 高级表单 -->
          <template v-else-if="activeTab === 'advanced-form'">
            <div class="gofo-card advanced-form-card">
              <!-- 订单录入 -->
              <div class="advanced-form-section-card">
                <div class="advanced-form-section-head">
                  <span class="advanced-form-section-title">订单录入</span>
                </div>
                <a-form layout="vertical" :model="advancedForm">
                  <a-row :gutter="24">
                    <a-col :span="8">
                      <a-form-item label="输入" name="input1" required>
                        <a-tooltip title="请输入客户地址，可参考订单管理">
                          <a-input v-model:value="advancedForm.input1" placeholder="请输入" />
                        </a-tooltip>
                      </a-form-item>
                    </a-col>
                    <a-col :span="8">
                      <a-form-item label="链接" name="link">
                        <a-input v-model:value="advancedForm.link" placeholder="请输入">
                          <template #addonBefore>https://</template>
                          <template #addonAfter>.com</template>
                        </a-input>
                      </a-form-item>
                    </a-col>
                    <a-col :span="8">
                      <a-form-item label="选择" name="select1" required>
                        <a-select v-model:value="advancedForm.select1" placeholder="请选择" :options="selectOptions" />
                      </a-form-item>
                    </a-col>
                    <a-col :span="8">
                      <a-form-item label="来源" name="source">
                        <a-select v-model:value="advancedForm.source" placeholder="请选择" :options="sourceOptions" />
                      </a-form-item>
                    </a-col>
                    <a-col :span="8">
                      <a-form-item label="生效日期" name="effectiveDate">
                        <a-range-picker v-model:value="advancedForm.effectiveDate" />
                      </a-form-item>
                    </a-col>
                    <a-col :span="8">
                      <a-form-item label="标签（多选）" name="tags">
                        <a-select v-model:value="advancedForm.tags" mode="tags" placeholder="请选择" :options="tagOptions" />
                      </a-form-item>
                    </a-col>
                  </a-row>
                </a-form>
              </div>

              <!-- 物流信息 -->
              <div class="advanced-form-section-card">
                <div class="advanced-form-section-head">
                  <span class="advanced-form-section-title">物流信息</span>
                  <a-button type="link" class="advanced-form-more-btn" @click="showMore = !showMore">
                    更多
                    <gofo-icon v-if="!showMore" type="down-outlined" class="advanced-form-more-icon"></gofo-icon>
                    <gofo-icon v-else type="up-outlined" class="advanced-form-more-icon"></gofo-icon>
                  </a-button>
                </div>
                <a-form layout="vertical" :model="advancedForm">
                  <a-row :gutter="24">
                    <a-col :span="8">
                      <a-form-item label="标签" name="label1">
                        <a-input v-model:value="advancedForm.label1" placeholder="请输入" />
                      </a-form-item>
                    </a-col>
                    <a-col :span="8">
                      <a-form-item label="标签" name="label2">
                        <a-input v-model:value="advancedForm.label2" placeholder="请输入" />
                      </a-form-item>
                    </a-col>
                    <a-col :span="8">
                      <a-form-item label="标签" name="label3">
                        <a-input v-model:value="advancedForm.label3" placeholder="请输入" />
                      </a-form-item>
                    </a-col>
                    <a-col :span="8">
                      <a-form-item label="标签" name="label4" :help="`${advancedForm.label4?.length || 0}/100`">
                        <a-input v-model:value="advancedForm.label4" placeholder="请输入" :maxlength="100" />
                      </a-form-item>
                    </a-col>
                    <a-col :span="8">
                      <a-form-item label="生效日期" name="effectiveDate2" required>
                        <a-date-picker v-model:value="advancedForm.effectiveDate2" placeholder="提醒日期" />
                      </a-form-item>
                    </a-col>
                    <a-col :span="8">
                      <a-form-item label="标签" name="label5">
                        <a-input v-model:value="advancedForm.label5" placeholder="请输入" />
                      </a-form-item>
                    </a-col>
                  </a-row>
                  <a-row v-if="showMore" :gutter="24" class="advanced-form-more-row">
                    <a-col :span="8">
                      <a-form-item label="物流公司" name="logisticsCompany">
                        <a-input v-model:value="advancedForm.logisticsCompany" placeholder="请输入" />
                      </a-form-item>
                    </a-col>
                    <a-col :span="8">
                      <a-form-item label="物流单号" name="trackingNumber">
                        <a-input v-model:value="advancedForm.trackingNumber" placeholder="请输入" />
                      </a-form-item>
                    </a-col>
                    <a-col :span="8">
                      <a-form-item label="发货时间" name="shippingTime">
                        <a-date-picker v-model:value="advancedForm.shippingTime" placeholder="请选择" />
                      </a-form-item>
                    </a-col>
                  </a-row>
                </a-form>
              </div>

              <!-- 管理 -->
              <div class="advanced-form-section-card">
                <div class="advanced-form-section-head">
                  <span class="advanced-form-section-title">管理</span>
                </div>
                <vxe-table :data="advancedForm.managementData" border stripe :column-config="{ resizable: true }" :row-config="{ isHover: true }">
                  <vxe-column field="title1" title="标题" min-width="140"></vxe-column>
                  <vxe-column field="title2" title="标题" min-width="240"></vxe-column>
                  <vxe-column field="title3" title="标题" min-width="140" align="right"></vxe-column>
                  <vxe-column field="title4" title="标题" min-width="140" align="right"></vxe-column>
                  <vxe-column title="操作" width="140" align="center">
                    <template #default="{ row, rowIndex }">
                      <a-tooltip title="编辑">
                        <a-button type="link" size="small" class="advanced-form-action-btn" @click="openEditDrawer(row, rowIndex)">
                          <gofo-icon type="edit-outlined" class="advanced-form-action-icon"></gofo-icon>
                        </a-button>
                      </a-tooltip>
                      <a-tooltip title="详情">
                        <a-button type="link" size="small" class="advanced-form-action-btn" @click="openDetailModal(advancedForm.managementData, rowIndex)">
                          <gofo-icon type="eye-outlined" class="advanced-form-action-icon"></gofo-icon>
                        </a-button>
                      </a-tooltip>
                      <a-tooltip title="删除">
                        <a-button type="link" size="small" class="advanced-form-action-btn" @click="removeManagementRow(rowIndex)">
                          <gofo-icon type="delete-outlined" class="advanced-form-action-icon"></gofo-icon>
                        </a-button>
                      </a-tooltip>
                    </template>
                  </vxe-column>
                </vxe-table>
                <a-button type="dashed" block class="advanced-form-add-btn" @click="addManagementRow">
                  <gofo-icon type="plus-outlined" class="advanced-form-add-icon"></gofo-icon>
                  新增
                </a-button>
              </div>

              <!-- 详情弹窗 -->
              <a-modal
                v-model:visible="detailModalVisible"
                title="详情"
                width="1200px"
                :footer="null"
                :closable="true"
                @cancel="closeDetailModal"
                class="advanced-form-detail-modal"
              >
                <a-form layout="inline" :model="detailRow" class="advanced-form-detail-filter">
                  <a-form-item label="标签">
                    <a-input v-model:value="detailRow.title1" placeholder="请输入" />
                  </a-form-item>
                  <a-form-item label="标签">
                    <a-select v-model:value="detailRow.title2" placeholder="请选择" style="width: 200px">
                      <a-select-option value="">请选择</a-select-option>
                      <a-select-option v-for="opt in selectOptions" :key="opt.value" :value="opt.value">{{ opt.label }}</a-select-option>
                    </a-select>
                  </a-form-item>
                  <a-form-item label="日期">
                    <a-date-picker v-model:value="detailRow.shippingTime" placeholder="请选择日期" />
                  </a-form-item>
                  <a-form-item>
                    <a-button size="middle" @click="closeDetailModal">重置</a-button>
                    <a-button size="middle" type="primary" style="margin-left: 8px" @click="closeDetailModal">查询</a-button>
                  </a-form-item>
                </a-form>
                <vxe-table :data="detailTableData" border stripe :column-config="{ resizable: true }" :row-config="{ isHover: true }">
                  <vxe-column type="checkbox" width="50" align="center"></vxe-column>
                  <vxe-column field="title" title="标题" min-width="140"></vxe-column>
                  <vxe-column field="desc" title="描述" min-width="360"></vxe-column>
                  <vxe-column field="num1" title="数值一" min-width="140" align="right"></vxe-column>
                  <vxe-column field="num2" title="数值二" min-width="140" align="right"></vxe-column>
                  <vxe-column field="num3" title="数值三" min-width="140" align="right"></vxe-column>
                  <vxe-column field="status" title="状态" min-width="100" align="center">
                    <template #default="{ row }">
                      <a-badge :status="row.status" :text="row.statusText" />
                    </template>
                  </vxe-column>
                  <vxe-column field="date" title="更新时间" min-width="200"></vxe-column>
                  <vxe-column title="操作" width="120" align="center" fixed="right">
                    <template #default>
                      <a-tooltip title="编辑">
                        <a-button type="link" size="small" class="advanced-form-action-btn">
                          <gofo-icon type="edit-outlined" class="advanced-form-action-icon"></gofo-icon>
                        </a-button>
                      </a-tooltip>
                      <a-tooltip title="详情">
                        <a-button type="link" size="small" class="advanced-form-action-btn">
                          <gofo-icon type="eye-outlined" class="advanced-form-action-icon"></gofo-icon>
                        </a-button>
                      </a-tooltip>
                      <a-tooltip title="删除">
                        <a-button type="link" size="small" class="advanced-form-action-btn">
                          <gofo-icon type="delete-outlined" class="advanced-form-action-icon"></gofo-icon>
                        </a-button>
                      </a-tooltip>
                    </template>
                  </vxe-column>
                </vxe-table>
                <div class="advanced-form-detail-footer">
                  <a-pagination
                    v-model:current="detailPagination.current"
                    v-model:page-size="detailPagination.pageSize"
                    :total="detailPagination.total"
                    show-size-changer
                    show-quick-jumper
                    :page-size-options="['10', '20', '50', '100']"
                    :show-total="(total) => `共 ${total} 条`"
                  />
                </div>
              </a-modal>

              <!-- 编辑抽屉 -->
              <a-drawer
                v-model:visible="editDrawerVisible"
                title="编辑管理项"
                width="520px"
                :footer="null"
                :closable="true"
                @close="closeEditDrawer"
                class="advanced-form-edit-drawer"
              >
                <a-form :model="editForm" layout="vertical" class="advanced-form-edit-form">
                  <a-form-item label="标题" name="title1">
                    <a-input v-model:value="editForm.title1" placeholder="请输入标题" />
                  </a-form-item>
                  <a-form-item label="类型" name="title2">
                    <a-select v-model:value="editForm.title2" placeholder="请选择类型">
                      <a-select-option value="">请选择</a-select-option>
                      <a-select-option v-for="opt in selectOptions" :key="opt.value" :value="opt.value">{{ opt.label }}</a-select-option>
                    </a-select>
                  </a-form-item>
                  <a-row :gutter="16">
                    <a-col :span="12">
                      <a-form-item label="数值一" name="title3">
                        <a-input-number v-model:value="editForm.title3" :min="0" placeholder="请输入" style="width: 100%" />
                      </a-form-item>
                    </a-col>
                    <a-col :span="12">
                      <a-form-item label="数值二" name="title4">
                        <a-input-number v-model:value="editForm.title4" :min="0" placeholder="请输入" style="width: 100%" />
                      </a-form-item>
                    </a-col>
                  </a-row>
                  <a-form-item label="状态" name="status">
                    <a-radio-group v-model:value="editForm.status">
                      <a-radio value="draft">草稿</a-radio>
                      <a-radio value="published">已发布</a-radio>
                      <a-radio value="archived">已归档</a-radio>
                    </a-radio-group>
                  </a-form-item>
                  <a-form-item label="备注" name="remark">
                    <a-textarea v-model:value="editForm.remark" :rows="4" placeholder="请输入备注信息" />
                  </a-form-item>
                </a-form>
                <div class="advanced-form-edit-footer">
                  <a-button size="middle" @click="closeEditDrawer">取消</a-button>
                  <a-button size="middle" type="primary" style="margin-left: 8px" @click="saveEditDrawer">保存</a-button>
                </div>
              </a-drawer>

              <!-- 底部操作 -->
              <div class="advanced-form-footer-actions">
                <a-button size="middle" @click="handleAdvancedFormReset">保存</a-button>
                <a-button size="middle" type="primary" style="margin-left: 8px" @click="handleAdvancedFormSubmit">提交</a-button>
              </div>
            </div>
          </template>

          <!-- 分步表单 -->
          <template v-else-if="activeTab === 'step-form'">
            <div class="gofo-card step-form-card">
              <a-steps :current="stepFormCurrent" class="step-form-steps">
                <a-step key="0" title="填写转账信息" @click="stepFormCurrent = 0"></a-step>
                <a-step key="1" title="确认转账信息" @click="stepFormCurrent = 1"></a-step>
                <a-step key="2" title="完成" @click="stepFormCurrent = 2"></a-step>
              </a-steps>

              <!-- 第一步：填写转账信息 -->
              <div v-if="stepFormCurrent === 0" class="step-form-content step-form-edit">
                <a-form :model="stepForm" layout="horizontal" :label-col="{ span: 5 }" :wrapper-col="{ span: 16 }" class="step-form">
                  <a-form-item label="付款账户" name="paymentAccount" :rules="[{ required: true, message: '请选择付款账户' }]">
                    <a-select v-model:value="stepForm.paymentAccount" placeholder="请选择" :options="stepFormPaymentAccounts" class="step-form-control" />
                  </a-form-item>
                  <a-form-item label="收款账户" name="receiverAccount" :rules="[{ required: true, message: '请输入收款账户' }]">
                    <a-input v-model:value="stepForm.receiverAccount" placeholder="请输入" class="step-form-control">
                      <template #addonBefore>
                        <a-select v-model:value="stepForm.receiverAccountType" style="width: 90px" :options="stepFormReceiverAccountTypes" />
                      </template>
                    </a-input>
                  </a-form-item>
                  <a-form-item label="收款人姓名" name="receiverName" :rules="[{ required: true, message: '请输入收款人姓名' }]">
                    <a-input v-model:value="stepForm.receiverName" placeholder="请输入收款人姓名" class="step-form-control" />
                  </a-form-item>
                  <a-form-item label="转账金额" name="amount" :rules="[{ required: true, message: '请输入转账金额' }]">
                    <a-input-number v-model:value="stepForm.amount" :min="0" prefix="¥" placeholder="请输入转账金额" class="step-form-control" />
                  </a-form-item>
                  <a-form-item label="转账类型" name="transferType">
                    <a-radio-group v-model:value="stepForm.transferType" :options="stepFormTransferTypes" />
                  </a-form-item>
                  <a-form-item v-if="stepForm.transferType === 'scheduled'" label="转账日期" name="transferDate" :rules="[{ required: true, message: '请选择转账日期' }]">
                    <a-date-picker v-model:value="stepForm.transferDate" placeholder="请选择日期" class="step-form-control" />
                  </a-form-item>
                  <a-form-item label="转账用途" name="purpose">
                    <a-select v-model:value="stepForm.purpose" placeholder="请选择转账用途" :options="stepFormPurposes" class="step-form-control" />
                  </a-form-item>
                  <a-form-item label="通知方式" name="notify">
                    <a-checkbox-group v-model:value="stepForm.notify" :options="stepFormNotifyOptions" />
                  </a-form-item>
                  <a-form-item label="备注" name="remark">
                    <a-textarea v-model:value="stepForm.remark" :rows="4" placeholder="请输入备注" class="step-form-control" />
                  </a-form-item>
                  <a-form-item name="agreement" class="step-form-agreement" :rules="[{ validator: (_rule, value) => value ? Promise.resolve() : Promise.reject('请同意转账协议') }]">
                    <a-checkbox v-model:checked="stepForm.agreement">我已阅读并同意转账协议</a-checkbox>
                  </a-form-item>
                  <a-form-item :wrapper-col="{ offset: 5, span: 16 }">
                    <a-button type="primary" @click="handleStepFormNext">下一步</a-button>
                  </a-form-item>
                </a-form>
              </div>

              <!-- 第二步：确认转账信息 -->
              <div v-if="stepFormCurrent === 1" class="step-form-content">
                <a-alert message="确认转账后，资金将直接转入对方账户，且无法退回。" type="warning" show-icon class="step-form-alert"></a-alert>
                <div class="step-form-confirm">
                  <div class="step-form-confirm-row"><span class="step-form-confirm-label">付款账户</span><span class="step-form-confirm-value">{{ stepForm.paymentAccount }}</span></div>
                  <div class="step-form-confirm-row"><span class="step-form-confirm-label">收款账户</span><span class="step-form-confirm-value">{{ stepFormReceiverAccountTypeLabel }} {{ stepForm.receiverAccount }}</span></div>
                  <div class="step-form-confirm-row"><span class="step-form-confirm-label">收款人姓名</span><span class="step-form-confirm-value">{{ stepForm.receiverName }}</span></div>
                  <div class="step-form-confirm-row"><span class="step-form-confirm-label">转账金额</span><span class="step-form-confirm-value step-form-amount">¥ {{ stepForm.amount }}</span></div>
                  <div class="step-form-confirm-row"><span class="step-form-confirm-label">转账类型</span><span class="step-form-confirm-value">{{ stepFormTransferTypes.find(t => t.value === stepForm.transferType)?.label }}</span></div>
                  <div v-if="stepForm.transferType === 'scheduled'" class="step-form-confirm-row"><span class="step-form-confirm-label">转账日期</span><span class="step-form-confirm-value">{{ stepForm.transferDate ? stepForm.transferDate.format('YYYY-MM-DD') : '-' }}</span></div>
                  <div class="step-form-confirm-row"><span class="step-form-confirm-label">转账用途</span><span class="step-form-confirm-value">{{ stepFormPurposes.find(p => p.value === stepForm.purpose)?.label }}</span></div>
                  <div class="step-form-confirm-row"><span class="step-form-confirm-label">通知方式</span><span class="step-form-confirm-value">{{ stepForm.notify.map(v => stepFormNotifyOptions.find(n => n.value === v)?.label).join('、') }}</span></div>
                  <div class="step-form-confirm-row"><span class="step-form-confirm-label">备注</span><span class="step-form-confirm-value">{{ stepForm.remark || '-' }}</span></div>
                </div>
                <div class="step-form-actions">
                  <a-button @click="handleStepFormPrev">上一步</a-button>
                  <a-button type="primary" style="margin-left: 8px" @click="handleStepFormSubmit">确认</a-button>
                </div>
              </div>

              <!-- 第三步：完成 -->
              <div v-if="stepFormCurrent === 2" class="step-form-content">
                <a-result status="success" title="操作成功" sub-title="">
                  <template #extra>
                    <a-button @click="handleStepFormAgain">再转一笔</a-button>
                    <a-button type="primary" style="margin-left: 8px">查看详情</a-button>
                  </template>
                  <div class="step-form-result-detail">
                    <a-descriptions :column="1">
                      <a-descriptions-item label="付款账户">{{ stepForm.paymentAccount }}</a-descriptions-item>
                      <a-descriptions-item label="收款账户">{{ stepFormReceiverAccountTypeLabel }} {{ stepForm.receiverAccount }}</a-descriptions-item>
                      <a-descriptions-item label="收款人姓名">{{ stepForm.receiverName }}</a-descriptions-item>
                      <a-descriptions-item label="转账金额"><span class="step-form-amount">¥ {{ stepForm.amount }}</span></a-descriptions-item>
                    </a-descriptions>
                  </div>
                </a-result>
              </div>


            </div>
          </template>

          <!-- 详情页 -->
          <template v-else-if="activeTab === 'detail'">
            <div class="gofo-card detail-section-card">
              <div class="detail-section-head">
                <h4 class="detail-section-title">产品信息</h4>
                <div class="detail-section-extra">
                  <a-button>操作一</a-button>
                  <a-button style="margin-left: 8px">操作二</a-button>
                  <a-button type="primary" style="margin-left: 8px">主操作</a-button>
                </div>
              </div>
              <vxe-table class="detail-product-table" :data="detailProductList" border stripe :column-config="{ resizable: true }" :row-config="{ isHover: true }">
                <vxe-column field="product" title="产品" min-width="200"></vxe-column>
                <vxe-column field="amount" title="数量" min-width="120"></vxe-column>
                <vxe-column field="unitPrice" title="单价" min-width="120"></vxe-column>
                <vxe-column field="totalPrice" title="总价" min-width="120"></vxe-column>
                <vxe-column field="status" title="状态" min-width="120"></vxe-column>
              </vxe-table>
              <a-descriptions :column="3" class="detail-info-desc">
                <a-descriptions-item label="申报货值（USD）">
                  <span class="detail-info-highlight">100000</span>
                </a-descriptions-item>
                <a-descriptions-item label="长 × 宽 × 高（cm）">
                  <span class="detail-info-highlight">100000</span>
                </a-descriptions-item>
                <a-descriptions-item label="复核重量（kg）">100000</a-descriptions-item>
                <a-descriptions-item label="结算重量（kg）">100000</a-descriptions-item>
                <a-descriptions-item label="产品类型">1000000</a-descriptions-item>
              </a-descriptions>
            </div>

            <div class="gofo-card detail-section-card">
              <div class="detail-section-head">
                <h4 class="detail-section-title">收发件人信息</h4>
                <div class="detail-section-extra">
                  <a-button>操作一</a-button>
                  <a-button type="primary" style="margin-left: 8px">主操作</a-button>
                </div>
              </div>
              <a-row :gutter="16">
                <a-col :span="12">
                  <a-card :bordered="true" class="detail-sub-card">
                    <template #title>
                      <div class="detail-sub-card-head">
                        <span class="detail-sub-card-title">发件人</span>
                        <a-button type="link">操作</a-button>
                      </div>
                    </template>
                    <a-descriptions :column="3" layout="vertical" class="detail-sub-desc">
                      <a-descriptions-item label="姓名">Chenshangyi</a-descriptions-item>
                      <a-descriptions-item label="手机号码">18812930492</a-descriptions-item>
                      <a-descriptions-item label="邮政编码">35013</a-descriptions-item>
                      <a-descriptions-item label="国家">China</a-descriptions-item>
                      <a-descriptions-item label="州/省">Mexico</a-descriptions-item>
                      <a-descriptions-item label="客户">DBU</a-descriptions-item>
                      <a-descriptions-item label="城市">Roman Sanche</a-descriptions-item>
                      <a-descriptions-item label="区域">Tlatelolco</a-descriptions-item>
                    </a-descriptions>
                  </a-card>
                </a-col>
                <a-col :span="12">
                  <a-card :bordered="true" class="detail-sub-card">
                    <template #title>
                      <div class="detail-sub-card-head">
                        <span class="detail-sub-card-title">收件人</span>
                        <a-button type="link">操作</a-button>
                      </div>
                    </template>
                    <a-descriptions :column="3" layout="vertical" class="detail-sub-desc">
                      <a-descriptions-item label="姓名">Chenshangyi</a-descriptions-item>
                      <a-descriptions-item label="手机号码">18812930492</a-descriptions-item>
                      <a-descriptions-item label="邮政编码">35013</a-descriptions-item>
                      <a-descriptions-item label="国家">China</a-descriptions-item>
                      <a-descriptions-item label="州/省">Mexico</a-descriptions-item>
                      <a-descriptions-item label="客户">DBU</a-descriptions-item>
                      <a-descriptions-item label="城市">Roman Sanche</a-descriptions-item>
                      <a-descriptions-item label="区域">Tlatelolco</a-descriptions-item>
                    </a-descriptions>
                  </a-card>
                </a-col>
              </a-row>
            </div>

            <div class="gofo-card detail-section-card">
              <div class="detail-section-head">
                <h4 class="detail-section-title">物流路由</h4>
                <div class="detail-section-extra">
                  <a-button>操作一</a-button>
                  <a-button style="margin-left: 8px">操作二</a-button>
                  <a-button type="primary" style="margin-left: 8px">主操作</a-button>
                </div>
              </div>
              <div class="detail-route-panel">
                <div class="detail-route-header">
                  <div class="detail-route-point">
                    <div class="detail-route-code">91761</div>
                    <div class="detail-route-location">US-CA-San Bernadino</div>
                  </div>
                  <div class="detail-route-arrows">
                    <span>&gt;&gt;</span>
                    <span>&gt;&gt;</span>
                    <span>&gt;&gt;</span>
                  </div>
                  <div class="detail-route-point">
                    <div class="detail-route-code">91761</div>
                    <div class="detail-route-location">US-CA-San Bernadino</div>
                  </div>
                </div>
                <a-steps :current="detailCurrentStep" progress-dot class="detail-route-steps">
                  <a-step v-for="(node, index) in routeNodes" :key="index" :title="node" />
                </a-steps>
              </div>
              <vxe-table :data="detailRelatedList" border stripe :column-config="{ resizable: true }" :row-config="{ isHover: true }">
                <vxe-column field="code" title="编码" min-width="120">
                  <template #default="{ row }">
                    <a>{{ row.code }}</a>
                  </template>
                </vxe-column>
                <vxe-column field="desc" title="描述" min-width="280"></vxe-column>
                <vxe-column field="num1" title="数值一" min-width="140" align="right"></vxe-column>
                <vxe-column field="num2" title="数值二" min-width="140" align="right"></vxe-column>
                <vxe-column field="status" title="状态" min-width="120" align="center">
                  <template #default="{ row }">
                    <span class="query-status-cell">
                      <span class="query-status-dot" :style="{ backgroundColor: statusTagMap[row.status]?.dotColor }"></span>
                      <span class="query-status-text">{{ statusTagMap[row.status]?.text }}</span>
                    </span>
                  </template>
                </vxe-column>
                <vxe-column field="date" title="更新时间" min-width="180"></vxe-column>
              </vxe-table>
              <div class="detail-pagination">
                <a-pagination
                  v-model:current="detailRelatedPagination.current"
                  v-model:page-size="detailRelatedPagination.pageSize"
                  :total="detailRelatedPagination.total"
                  show-size-changer
                  show-quick-jumper
                  :page-size-options="['10', '20', '50', '100']"
                  :show-total="(total, range) => `共 ${total} 条`"
                />
              </div>
            </div>
          </template>

          <!-- 成功页 -->
          <template v-else-if="activeTab === 'success'">
            <div class="gofo-card result-page-card">
              <a-result status="success" title="创建成功">
                <template #subTitle>
                  <div>订单号：GFUS01020989801536</div>
                  <div>云服务器配置需要 1-5 分钟，请稍候。</div>
                </template>
                <template #extra>
                  <a-button>再次创建</a-button>
                  <a-button type="primary" style="margin-left: 8px">查看详情</a-button>
                </template>
              </a-result>
            </div>
          </template>

          <!-- 失败页 -->
          <template v-else-if="activeTab === 'fail'">
            <div class="gofo-card result-page-card">
              <a-result status="error" title="提交失败" sub-title="请核对并修改以下信息后，再重新提交。">
                <template #extra>
                  <a-button>重新提交</a-button>
                  <a-button type="primary" style="margin-left: 8px">返回修改</a-button>
                </template>
              </a-result>
            </div>
          </template>

          <!-- 403 -->
          <template v-else-if="activeTab === '403'">
            <div class="gofo-card result-page-card">
              <a-result status="403" title="403" sub-title="抱歉，你无权访问该页面。">
                <template #extra>
                  <a-button type="primary">返回首页</a-button>
                </template>
              </a-result>
            </div>
          </template>

          <!-- 404 -->
          <template v-else-if="activeTab === '404'">
            <div class="gofo-card result-page-card">
              <a-result status="404" title="404" sub-title="抱歉，你访问的页面不存在。">
                <template #extra>
                  <a-button type="primary">返回首页</a-button>
                </template>
              </a-result>
            </div>
          </template>

          <!-- 500 -->
          <template v-else-if="activeTab === '500'">
            <div class="gofo-card result-page-card">
              <a-result status="500" title="500" sub-title="抱歉，服务器出错了。">
                <template #extra>
                  <a-button type="primary">返回首页</a-button>
                </template>
              </a-result>
            </div>
          </template>

          <!-- 其他页面占位 -->
          <template v-else>
            <div class="gofo-card frame1"></div>
            <div class="gofo-card frame2"></div>
          </template>
        </div>
      </main>
    </div>
    </a-config-provider>
  </div>

  <script>
    const { createApp, h } = Vue;

    const GofoIcon = {
      props: ['type'],
      setup(props) {
        return () => h('svg', { class: 'gofo-icon' }, [
          h('use', { 'xlink:href': '#icon-' + props.type })
        ]);
      }
    };

    createApp({
      components: { GofoIcon },
      setup() {
        const menu = [
          {
            key: 'foundation',
            label: '基本框架',
            icon: 'appstore',
          },
          {
            key: 'dashboard',
            label: '数据看板',
            icon: 'dashboard',
            children: [
              { key: 'dashboard-basic', label: '基础模版' },
              { key: 'dashboard-visual', label: '强视觉模版' },
              { key: 'data-screen', label: '数据大屏' },
            ],
          },
          {
            key: 'form',
            label: '表单页',
            icon: 'form',
            children: [
              { key: 'basic-form', label: '基础表单' },
              { key: 'advanced-form', label: '高级表单' },
              { key: 'step-form', label: '分步表单' },
            ],
          },
          {
            key: 'list',
            label: '列表页',
            icon: 'table',
            children: [
              { key: 'query-table', label: '查询表格' },
              { key: 'card-list', label: '卡片列表' },
            ],
          },
          { key: 'detail', label: '详情页', icon: 'profile' },
          {
            key: 'result',
            label: '结果页',
            icon: 'check-circle',
            children: [
              { key: 'success', label: '成功页' },
              { key: 'fail', label: '失败页' },
            ],
          },
          {
            key: 'exception',
            label: '异常页',
            icon: 'warning',
            children: [
              { key: '403', label: '403' },
              { key: '404', label: '404' },
              { key: '500', label: '500' },
            ],
          },
        ];

        const menuMap = {};
        menu.forEach((item) => {
          menuMap[item.key] = item.label;
          item.children?.forEach((child) => {
            menuMap[child.key] = child.label;
          });
        });

        const searchKeyword = Vue.ref('');
        const searchFocused = Vue.ref(false);
        const searchCloseTimer = Vue.ref(null);
        const startSearchClose = () => {
          searchCloseTimer.value = setTimeout(() => { searchFocused.value = false; }, 120);
        };
        const cancelSearchClose = () => {
          if (searchCloseTimer.value) {
            clearTimeout(searchCloseTimer.value);
            searchCloseTimer.value = null;
          }
        };
        const openSearchResults = () => {
          cancelSearchClose();
          searchFocused.value = true;
        };
        const searchResults = Vue.computed(() => {
          const kw = searchKeyword.value.trim().toLowerCase();
          if (!kw) return [];
          const results = [];
          menu.forEach((item) => {
            if (item.children) {
              item.children.forEach((child) => {
                if (child.label.toLowerCase().includes(kw)) {
                  results.push({ key: child.key, label: `${item.label} / ${child.label}` });
                }
              });
            } else if (item.label.toLowerCase().includes(kw)) {
              results.push({ key: item.key, label: item.label });
            }
          });
          return results;
        });
        const handleSearchSelect = (key) => {
          selectMenu(key);
          searchKeyword.value = '';
          searchFocused.value = false;
          cancelSearchClose();
        };

        const activeMenu = Vue.ref('dashboard-basic');
        const activeTab = Vue.ref('dashboard-basic');
        const showMore = Vue.ref(false);
        const showMoreFilter = Vue.ref(false);
        const queryFilterExpanded = Vue.ref(false);
        const queryTableFullscreen = Vue.ref(false);
        const expandedMenus = Vue.ref([]);
        const sidebarExpanded = Vue.ref(false);
        const language = Vue.ref('中文');
        const timezone = Vue.ref('北京时间');

        const noticeDropdownOpen = Vue.ref(false);
        const noticeTooltipOpen = Vue.ref(false);
        const langDropdownOpen = Vue.ref(false);
        const langTooltipOpen = Vue.ref(false);
        const tzDropdownOpen = Vue.ref(false);
        const tzTooltipOpen = Vue.ref(false);
        const userDropdownOpen = Vue.ref(false);
        const userTooltipOpen = Vue.ref(false);

        Vue.watch(noticeDropdownOpen, (val) => { if (val) noticeTooltipOpen.value = false; });
        Vue.watch(langDropdownOpen, (val) => { if (val) langTooltipOpen.value = false; });
        Vue.watch(tzDropdownOpen, (val) => { if (val) tzTooltipOpen.value = false; });
        Vue.watch(userDropdownOpen, (val) => { if (val) userTooltipOpen.value = false; });

        const useHoverClose = (openRef) => {
          const timer = Vue.ref(null);
          const start = () => {
            timer.value = setTimeout(() => { openRef.value = false; }, 120);
          };
          const cancel = () => {
            if (timer.value) {
              clearTimeout(timer.value);
              timer.value = null;
            }
          };
          return { start, cancel };
        };
        const { start: startNoticeClose, cancel: cancelNoticeClose } = useHoverClose(noticeDropdownOpen);
        const { start: startLangClose, cancel: cancelLangClose } = useHoverClose(langDropdownOpen);
        const { start: startTzClose, cancel: cancelTzClose } = useHoverClose(tzDropdownOpen);
        const { start: startUserClose, cancel: cancelUserClose } = useHoverClose(userDropdownOpen);

        const noticeActiveTab = Vue.ref('notice');
        const noticeTabs = Vue.ref([
          { key: 'notice', label: 'Notice', count: 2 },
          { key: 'message', label: 'Message', count: 2 },
          { key: 'todo', label: 'To-do', count: 0 },
        ]);
        const noticeData = {
          notice: [
            { id: 1, title: 'System 2.0 has been released', desc: 'The latest version of the system has been launched today' },
            { id: 2, title: 'Title', desc: 'Content ContentContentContentContentContentContentContent' },
          ],
          message: [
            { id: 3, title: 'New comment', desc: 'Tom commented on your post' },
            { id: 4, title: 'Task assigned', desc: 'A new task has been assigned to you' },
          ],
          todo: [
            { id: 5, title: 'Complete profile', desc: 'Please complete your personal information' },
          ],
        };
        const noticeList = Vue.computed(() => noticeData[noticeActiveTab.value] || []);
        const noticeTotalCount = Vue.computed(() => noticeTabs.value.reduce((sum, t) => sum + t.count, 0));

        const tabs = Vue.ref([
          { key: 'dashboard-basic', label: '基础模版' },
        ]);

        const closeTab = (key) => {
          const idx = tabs.value.findIndex(t => t.key === key);
          if (idx > -1) {
            tabs.value.splice(idx, 1);
            if (activeTab.value === key) {
              activeTab.value = tabs.value[0]?.key || 'dashboard';
            }
          }
        };

        const closeAllTabs = () => {
          tabs.value = tabs.value.filter(t => !t.closable);
          activeTab.value = tabs.value[0]?.key || 'dashboard';
        };

        const tabsContainerRef = Vue.ref(null);
        const tabWidths = Vue.ref({});

        const measureTabWidths = () => {
          const measureEl = document.createElement('div');
          measureEl.style.cssText = 'position: absolute; visibility: hidden; display: flex; gap: 4px; padding-left: 16px;';
          document.body.appendChild(measureEl);
          tabs.value.forEach(tab => {
            const el = document.createElement('div');
            el.className = 'gofo-tab-card';
            el.innerHTML = `<span>${tab.label}</span>${tab.closable ? '<span class="gofo-tab-close">×</span>' : ''}`;
            measureEl.appendChild(el);
            tabWidths.value[tab.key] = el.offsetWidth;
            measureEl.removeChild(el);
          });
          document.body.removeChild(measureEl);
        };

        Vue.onMounted(() => {
          measureTabWidths();
          window.addEventListener('resize', measureTabWidths);
          // Default open dashboard basic
          selectMenu('dashboard-basic');
        });

        Vue.watch(() => tabs.value.length, measureTabWidths);

        const visibleTabs = Vue.computed(() => {
          if (!tabsContainerRef.value) return tabs.value;
          const containerW = tabsContainerRef.value.clientWidth;
          const extraW = 120;
          let available = containerW - extraW;
          let count = 0;
          let used = 0;
          for (let i = 0; i < tabs.value.length; i++) {
            const w = tabWidths.value[tabs.value[i].key] || 100;
            if (used + w <= available) {
              used += w;
              count++;
            } else {
              break;
            }
          }
          if (count >= tabs.value.length) return tabs.value;
          return tabs.value.slice(0, count);
        });

        const hiddenTabs = Vue.computed(() => {
          if (visibleTabs.value.length === tabs.value.length) return [];
          return tabs.value.slice(visibleTabs.value.length);
        });

        const selectMenu = (key) => {
          activeMenu.value = key;
          activeTab.value = key;
          if (!tabs.value.find((t) => t.key === key)) {
            tabs.value.push({ key, label: menuMap[key], closable: true });
          }
          if (sidebarExpanded.value) {
            const parentKey = findParentMenuKey(key);
            expandedMenus.value = parentKey ? [parentKey] : [];
          }
        };

        const toggleMenu = (key) => {
          const idx = expandedMenus.value.indexOf(key);
          if (idx > -1) {
            expandedMenus.value = [];
          } else {
            expandedMenus.value = [key];
          }
        };

        const findParentMenuKey = (key) => {
          for (const item of menu) {
            if (item.children?.some((child) => child.key === key)) {
              return item.key;
            }
          }
          return null;
        };

        const handleSidebarEnter = () => {
          sidebarExpanded.value = true;
          const parentKey = findParentMenuKey(activeMenu.value);
          expandedMenus.value = parentKey ? [parentKey] : [];
        };

        const handleSidebarLeave = () => {
          sidebarExpanded.value = false;
          expandedMenus.value = [];
        };

        // 查询表格数据
        const defaultQueryTableColumns = [
          { field: 'name', title: '规则名称', minWidth: 180, visible: true, fixed: null },
          { field: 'desc', title: '描述', minWidth: 260, visible: true, fixed: null },
          { field: 'callNo', title: '服务调用次数', minWidth: 140, align: 'right', visible: true, fixed: null },
          { field: 'type', title: '类型', minWidth: 120, visible: true, fixed: null },
          { field: 'owner', title: '负责人', minWidth: 120, visible: true, fixed: null },
          { field: 'department', title: '部门', minWidth: 140, visible: true, fixed: null },
          { field: 'status', title: '状态', minWidth: 120, align: 'center', visible: true, fixed: null },
          { field: 'progress', title: '进度', minWidth: 120, align: 'right', visible: true, fixed: null },
          { field: 'amount', title: '金额', minWidth: 140, align: 'right', visible: true, fixed: null },
          { field: 'updatedAt', title: '更新时间', minWidth: 180, visible: true, fixed: null },
        ];

        const queryTableColumns = Vue.ref(defaultQueryTableColumns.map((c) => ({ ...c })));
        const columnSettingDraft = Vue.ref([]);
        const columnSettingOpen = Vue.ref(false);

        const visibleQueryColumns = Vue.computed(() => queryTableColumns.value.filter((c) => c.visible));

        /* 基本框架数据 */
        const foundationColors = Vue.ref([
          { name: 'primary-50', value: '#fff7e6' },
          { name: 'primary-100', value: '#ffe7ba' },
          { name: 'primary-200', value: '#ffd591' },
          { name: 'primary-300', value: '#ffc069' },
          { name: 'primary-400', value: '#ffa940' },
          { name: 'primary-500', value: '#fc4c02' },
          { name: 'primary-600', value: '#f26e35' },
          { name: 'primary-700', value: '#e84702' },
          { name: 'primary-800', value: '#d14104' },
          { name: 'primary-900', value: '#ad2102' },
        ]);
        const foundationStatusColors = Vue.ref([
          { name: '成功', value: '#52c41a' },
          { name: '警告', value: '#faad14' },
          { name: '错误', value: '#ff4d4f' },
          { name: '信息', value: '#1890ff' },
        ]);


        const queryForm = Vue.ref({
          name: '',
          status: undefined,
          dateRange: [],
          type: undefined,
          owner: '',
          department: undefined,
          minAmount: undefined,
          maxAmount: undefined,
        });

        const queryStatusOptions = [
          { label: '全部', value: '' },
          { label: '运行中', value: '0' },
          { label: '成功', value: '1' },
          { label: '异常', value: '2' },
          { label: '失败', value: '3' },
        ];

        const queryTypeOptions = [
          { label: '全部', value: '' },
          { label: '默认类型', value: '默认类型' },
          { label: '特殊类型', value: '特殊类型' },
        ];

        const queryDepartmentOptions = [
          { label: '全部', value: '' },
          { label: '技术部', value: '技术部' },
          { label: '产品部', value: '产品部' },
          { label: '运营部', value: '运营部' },
          { label: '市场部', value: '市场部' },
        ];

        const queryTableData = Vue.ref([
          { id: '1', name: 'TradeCode 100', desc: '这是一段描述', callNo: 887, type: '默认类型', owner: '张三', department: '技术部', status: '0', progress: '40%', amount: '39,505.19', updatedAt: '2024-01-01 10:00:00' },
          { id: '2', name: 'TradeCode 99', desc: '这是一段描述', callNo: 965, type: '默认类型', owner: '李四', department: '产品部', status: '1', progress: '38%', amount: '13,372.85', updatedAt: '2024-01-02 10:00:00' },
          { id: '3', name: 'TradeCode 98', desc: '这是一段描述', callNo: 186, type: '默认类型', owner: '王五', department: '运营部', status: '3', progress: '58%', amount: '43,761.52', updatedAt: '2024-01-03 10:00:00' },
          { id: '4', name: 'TradeCode 97', desc: '这是一段描述', callNo: 407, type: '默认类型', owner: '赵六', department: '市场部', status: '0', progress: '2%', amount: '8,320.58', updatedAt: '2024-01-04 10:00:00' },
          { id: '5', name: 'TradeCode 96', desc: '这是一段描述', callNo: 585, type: '默认类型', owner: '孙七', department: '设计部', status: '1', progress: '61%', amount: '28,825.92', updatedAt: '2024-01-05 10:00:00' },
          { id: '6', name: 'TradeCode 95', desc: '这是一段描述', callNo: 741, type: '默认类型', owner: '周八', department: '财务部', status: '2', progress: '73%', amount: '17,526.36', updatedAt: '2024-01-06 10:00:00' },
          { id: '7', name: 'TradeCode 94', desc: '这是一段描述', callNo: 412, type: '默认类型', owner: '吴九', department: '人事部', status: '3', progress: '84%', amount: '21,391.98', updatedAt: '2024-01-07 10:00:00' },
          { id: '8', name: 'TradeCode 93', desc: '这是一段描述', callNo: 538, type: '默认类型', owner: '郑十', department: '销售部', status: '1', progress: '66%', amount: '38,183.27', updatedAt: '2024-01-08 10:00:00' },
          { id: '9', name: 'TradeCode 92', desc: '这是一段描述', callNo: 327, type: '默认类型', owner: '钱十一', department: '客服部', status: '2', progress: '26%', amount: '51,298.09', updatedAt: '2024-01-09 10:00:00' },
          { id: '10', name: 'TradeCode 91', desc: '这是一段描述', callNo: 427, type: '默认类型', owner: '王十二', department: '行政部', status: '0', progress: '46%', amount: '6,377.00', updatedAt: '2024-01-10 10:00:00' },
        ]);

        const queryPagination = Vue.ref({
          current: 1,
          pageSize: 10,
          total: 100,
        });

        const courierFilterExpanded = Vue.ref(false);
        const courierForm = Vue.ref({
          name: '',
          phone: '',
          province: undefined,
          city: undefined,
          site: undefined,
          employeeNo: '',
          entryDateRange: [],
          status: undefined,
        });
        const courierProvinceOptions = [
          { label: '全部', value: '' },
          { label: '北京市', value: '北京市' },
          { label: '上海市', value: '上海市' },
          { label: '广东省', value: '广东省' },
          { label: '浙江省', value: '浙江省' },
          { label: '江苏省', value: '江苏省' },
          { label: '四川省', value: '四川省' },
          { label: '湖北省', value: '湖北省' },
          { label: '河南省', value: '河南省' },
        ];
        const courierCityOptions = [
          { label: '全部', value: '' },
          { label: '北京市', value: '北京市' },
          { label: '上海市', value: '上海市' },
          { label: '广州市', value: '广州市' },
          { label: '深圳市', value: '深圳市' },
          { label: '杭州市', value: '杭州市' },
          { label: '南京市', value: '南京市' },
          { label: '成都市', value: '成都市' },
          { label: '武汉市', value: '武汉市' },
          { label: '郑州市', value: '郑州市' },
        ];
        const courierSiteOptions = [
          { label: '全部', value: '' },
          { label: '朝阳站', value: '朝阳站' },
          { label: '海淀站', value: '海淀站' },
          { label: '浦东站', value: '浦东站' },
          { label: '徐汇站', value: '徐汇站' },
          { label: '天河站', value: '天河站' },
          { label: '南山站', value: '南山站' },
          { label: '西湖站', value: '西湖站' },
          { label: '鼓楼站', value: '鼓楼站' },
          { label: '锦江站', value: '锦江站' },
          { label: '武昌站', value: '武昌站' },
          { label: '金水站', value: '金水站' },
        ];
        const courierStatusOptions = [
          { label: '全部', value: '' },
          { label: '在职', value: '在职' },
          { label: '离职', value: '离职' },
          { label: '休假', value: '休假' },
