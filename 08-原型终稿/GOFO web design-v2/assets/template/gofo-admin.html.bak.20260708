        const dataScreenTrendChart = Vue.ref(null);
        const dataScreenRankChart = Vue.ref(null);
        const dataScreenVehicleChart = Vue.ref(null);
        const dataScreenSiteChart = Vue.ref(null);
        let dataScreenChartInstances = [];

        const dataScreenKpiList = Vue.ref([
          { label: '今日派送量', value: '128,456', color: '#fc4c02', icon: 'rise-outlined', trendIcon: 'arrow-up-outlined', trend: '+12.5% 环比昨日', trendType: 'up' },
          { label: '在途车辆', value: '2,847', color: '#1677ff', icon: 'car', trendIcon: 'minus', trend: '覆盖 48 个州', trendType: 'neutral' },
          { label: '异常票数', value: '326', color: '#ff4d4f', icon: 'warning', trendIcon: 'arrow-up-outlined', trend: '+8 较上小时', trendType: 'down' },
          { label: '准时妥投率', value: '96.8%', color: '#52c41a', icon: 'clock-circle-outlined', trendIcon: 'arrow-up-outlined', trend: '+0.8% 环比昨日', trendType: 'up' },
          { label: '活跃站点', value: '1,240', color: '#faad14', icon: 'shop-outlined', trendIcon: 'arrow-up-outlined', trend: '+15 新增上线', trendType: 'up' },
          { label: '平均派送时长', value: '18.5min', color: '#13c2c2', icon: 'dashboard', trendIcon: 'arrow-down-outlined', trend: '-1.2min 环比昨日', trendType: 'up' },
        ]);

