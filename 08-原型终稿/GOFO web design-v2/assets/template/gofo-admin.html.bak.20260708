            const delivered = Math.floor(should * (0.6 + Math.random() * 0.35));
            return {
              id: 'rdriver-' + i,
              name: ['Jack Chen', 'Tom Liu', 'Mike Wang', 'David Zhang', 'Alex Li'][i],
              should,
              delivered,
              delivering: Math.floor(Math.random() * 20),
